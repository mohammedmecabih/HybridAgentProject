; ********************************************************************************************************************************************************
;***          testcases.nls  (contains the code for the speciic testfunctions)                                                                                    ****
;*********************************************************************************************************************************************************
; TEST-CASE VERSION NUMMER: TC02
;*********************************************************************************************************************************************************
; DESCRIPTION OF THE TESTCASE
; - The testcase eliminates first all other agents and then creates three specific agents:
;              - "wolf01" as agentA, double normal size, with individual setup that should force it to visit a friend (=wolf02) and to then build a family with.
;              - "wolf02" as agentA, double normal size, with individual setup that should force it to visit a friend (=wolf01) and to then build a family with.
;              - "wolf03" as agentA, double normal size, with individual setup that should result in hunting the sheep as agentB
;              - "sheep" as agentB, double the normal size, same setup and behavior as agentB
;
; - The testcase overrides the setup values and update_environment_info for agentAs in every loop by:
;       - only first time: set wolf01 and wolf02 as mutual friends in the friendLists and as followFriends
;                          for wolf03 set huntAgent sheep
;       - every time: if proState = VisitingFriend, set visitFriend true
;
;- Expected simulation:
;   - wolf01 and wolf02 should visit each other and build a family and hatch an agentA
;   - wolf03 should hunt the sheep
;   - the sheep should detect that it is being hunted by wolf03 and escape to Sanctuary
; 
; - TERMINATION condition: endOfDay
;
; - Loggfile of the results: "BasicTemplate-testcase_TC02.txt"
;*********************************************************************************************************************************************************
;*********************************************************************************************************************************************************
; LOGBOOK OF UPDATES IN THIS FILE
; --Date--- |-----Description--------------------------------------------------------------------------------|---Person(s)-------------------------------
; 20260304    Initial testcase with a wolf for agentA and a sheep for agentB                                     Gion
;
;
;
;********************end logbook ************************************************************************************************************************


;*********************************************************************************************************************************************************
; GLOBAL VARIABLES ONLY FOR TEST CASES
; do not include it in globals.nls
globals [
   
  oldfriend
  oldstalker
  oldState
  oldfollowFriend
  oldfriendList
  oldfollowFlag
  ;oldmoveFlag
]
; agent-specific variables for the test case
; do not include in the agents declaration files
agentAs-own [
  oldProState
  firstFlag
]


;****************** end test-specific global variabless **************************************************************************************************************

;*********************************************************************************************************************************************************
; Testfunctions to be called in the setup-part
;
to setup-testagents
  ; test-delete all the other agents first
  ask turtles [
    set dateOfDeath time:plus current-time 0 "hour"; will kill everybody else
  ]
  
  
  ; create special test agent that will visit a Friend and build a family with
  create-agentAs 1 [
   set label "wolf01"
      set shape "wolf" 
      set size 2
      set color (red - 2)
      move-to one-of patches with [region = "house"]
      ; save the home location
      set homeLoc patch-here
      ;setxy [pxcor] of homeLoc [pycor] of homeLoc 
      set friend []
      set followFriend []
      set huntAgent []
      set friendList turtle-set []
      set friends ""
      set vision 2
      set fmax 7
      ; initial values of flags
      set followFlag false 
      set moveFlag false
      set proState "AtHome"
      set collectFriends false
      set visitFriend true;------------set true
      set friendFound false
      set goHomeFlag false
      set huntingFlag false
      set newFamily false 
    
      set makeFriendcount 0
      set reachFriendcount 0 
    
      set dateOfDeath time:plus current-time random 720 "hour" ; will live 10x longer than everybody else
    
      set oldProState "AtHome"
      set firstFlag true
  ]
  ; create special test agent that will visit a Friend and build a family with
  create-agentAs 1 [
   set label "wolf02"
      set shape "wolf" 
      set size 2
      set color (red - 2)
      move-to one-of patches with [region = "house"]
      ; save the home location
      set homeLoc patch-here
      ;setxy [pxcor] of homeLoc [pycor] of homeLoc 
      set friend []
      set followFriend []
      set huntAgent []
      set friendList turtle-set []
      set friends ""
      set vision 2
      set fmax 7
      ; initial values of flags
      set followFlag false 
      set moveFlag false
      set proState "AtHome"
      set collectFriends false
      set visitFriend true;------------set true
      set friendFound false
      set goHomeFlag false
      set huntingFlag false
      set newFamily false 
    
      set makeFriendcount 0
      set reachFriendcount 0 
    
      set dateOfDeath time:plus current-time random 720 "hour" ; will live 10x longer than everybody else
    
      set oldProState "AtHome"
      set firstFlag true
  ]
  create-agentAs 1 [
   set label "wolf03"
      set shape "wolf" 
      set size 2
      set color (red - 2)
      move-to one-of patches with [region = "house"]
      ; save the home location
      set homeLoc patch-here
      ;setxy [pxcor] of homeLoc [pycor] of homeLoc 
      set friend []
      set followFriend []
      set huntAgent []
      set friendList turtle-set []
      set friends ""
      set vision 2
      set fmax 7
      ; initial values of flags
      set followFlag false 
      set moveFlag false
      ;set proState "AtHome"
      set proState "HuntingAgentB"
      set collectFriends false
      set visitFriend false
      set friendFound false
      set goHomeFlag false
      ;set huntingFlag false
      set huntingFlag true
      set newFamily false 
    
      set makeFriendcount 0
      set reachFriendcount 0 
    
      set dateOfDeath time:plus current-time random 720 "hour"
    
      set oldProState ""
      set firstFlag true
  ]
  
  create-agentBs 1 [
   set label "sheep"
      set shape "sheep" 
      set size 2
      set color (lime + 3)
    move-to one-of patches with [region = "house"]
    ; save the home location
    ; save the home location
    set homeLoc patch-here
    set agAlarm1 0
    set follower []
    set oldFollower []
    set countTicks 0
    set identNr 0
    set state "State_MoveAround"
    set nr 0
    set dateOfDeath time:plus current-time random 720 "hour"
  ]
  
  ; set global variables, open file
  file-open "HybridTemplate-testcase_TC02.txt" 
  
    
  set oldfriend []
  set oldfollowFriend []
  set oldfriendList turtle-set []
  set oldfollowFlag false
  ;set oldmoveFlag true
  set oldstalker []
  
end ;setup-testagents

;****************** end setup part test functions *************************************************************************************************

;*********************************************************************************************************************************************************
; Testfunctions to be called in the to-go part, 
; after the ask turtles, in the observer-section 
;
to monitor_testagents
  run "monitor_wolf"
  run "monitor_sheep"
  ; terminate when sheep is in state "State_Sancturay"
  ;let agent agentBs with [label = "sheep"]
  ;let sheepstate item 0 [state] of agent ; [state] of agent returns an agent-set, with item 0 the first (and only) item is removed as an agent.
  ;if sheepstate = "State_Sanctuary"[
  ;file-close
  ;set TERMINATE true
  ;]
  ; terminate at the end of the day
  if endOfDay [
    file-close
    set TERMINATE true
  ]

end


to monitor_wolf
  ; monitoring important changes, writing directly into the text file
  ; wolf01
  let agent1 agentAs with [label = "wolf01"]
  ask agent1[  
  if (proState != oldProState)[
    file-print (word show-time ", " label ", change in proactive state from; " oldProState ", to: " proState)
    set oldProState proState
    ]
  ]
  ; wolf02
  let agent2 agentAs with [label = "wolf02"]
  ask agent2[  
  if (proState != oldProState)[
    file-print (word show-time ", " label ", change in proactive state from; " oldProState ", to: " proState)
    set oldProState proState
    ]
  ]
  ;wolf03
  let agent3 agentAs with [label = "wolf03"]
  ask agent3[  
  if (proState != oldProState)[
    file-print (word show-time ", " label ", change in proactive state from; " oldProState ", to: " proState)
    set oldProState proState
    ]
  ]
end

to monitor_sheep
  ; monitoring important changes, writing directly into the text file
  let agent agentBs with [label = "sheep"]
  
  ;let currentfollower [follower] of agent
  ;if (currentfollower != oldstalker)[
  ;  file-print (word show-time ", " [label] of agent ", change in follower from; " oldstalker ", to: " currentfollower)
  ;  set oldstalker currentfollower
  ;]
  let currentState [state] of agent
  if (currentState != oldState)[
    file-print (word show-time ", " [label] of agent ", change in state from; " oldState ", to: " currentState)
    set oldState currentState
  ]
  ; currentState is a list and not a string, get the string by selecting item 0
  ;let sheepstate item 0 currentState
  ;if (sheepstate = "State_Sanctuary") [
  ;file-close
  ;set TERMINATE true
  ;]
end
;****************** end to-go part test functions *************************************************************************************************

;*********************************************************************************************************************************************************
; Specific Testfunctions to be called in the agents' code
; - called within agentA.nls
;
to override_agentASetup
  ; called in every loop
  ; for agents wolf01 and wolf02:
  ; - first time only:
  ;        - set other agentAs into friendLists (fmax) first 
  ;        - set each other as followFriends
  ; - every time:
  ;
  ;        - if proState = VisitingFriend, set visitFriend true
  ;        - (if proState = BuildingFamily, set visitFriend false) probably not needed
  ask agentAs with [label = "wolf01"][
    ; if first time
    ifelse firstFlag [
      set friendList n-of fmax agentAs
      set friends sort friendList
      set followFriend (one-of agentAs with [label = "wolf02"])
      set firstFlag false
    ]
    [
      if proState = "VisitingFriend" [set visitFriend true]
    ]
  ]
  ask agentAs with [label = "wolf02"][
    ; if first time
    ifelse firstFlag [
      set friendList n-of fmax agentAs
      set friends sort friendList
      set followFriend (one-of agentAs with [label = "wolf01"])
      set firstFlag false
    ]
    [
      if proState = "VisitingFriend" [set visitFriend true]
    ]
  ]
  ask agentAs with [label = "wolf03"][
    if firstFlag [set huntAgent (one-of agentBs with [label = "sheep"])
      set firstFlag false
    ]
  ]
   
end
;****************** end specific testfunctions in agent's code *************************************************************************************************