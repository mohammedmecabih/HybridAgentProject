; ********************************************************************************************************************************************************
;***          AGENTA.NLS  (contains all the code for the agentA)                                                                                    ****
;*********************************************************************************************************************************************************
; DESCRIPTION OF THE AGENT
; - Lives in one of the houses upon creation.
; - Moves around to find friends. If it meets another agent it saves a reference to the agent in the 'friendList'.
; - Once friendList contains fmax friends, the agent stops adding other agents to the list, instead it checks if agents that it meets are in their friendList
; - if another agent is in the friendList it starts following that friend
;
;*********************************************************************************************************************************************************
; LOGBOOK OF UPDATES IN THIS FILE
; --Date--- |-----Description--------------------------------------------------------------------------------|---Person(s)-------------------------------
; 20260307    Initial template of a dummy-breed to be adapted by the project group                               Gion
;
;
;
;********************end logbook ************************************************************************************************************************
;*********************************************************************************************************************************************************
; LOCAL VARIABLES
agentAs-own [
  ; some examples of possible local variables, -replace with your own
  
  nearbyAgents;---List of the agents nearby
  vision;---------how long nearby is defined as
  fmax;-----------maximum members of friends
  friend;---------potential friend to add or follow
  followFriend;---selected friend to follow
  friendList;-----agent set of other citizen agents that are considered as friends
  friends;--------list with numbers of agents (same as friendList, but as a sorted list)
  huntAgent;------
  buildNewHome;--
  
  moveFlag;-------Flag to indicate the situation of moving freely around
  followFlag;-----Flag to indicate the situation of following a friend
  collectFriends;-Flag to indicate the situation of adding agents to friendList
  visitFriend;--- Flag to indicate visit of followFriend
  friendFound;--- Flag to indicate when friend has been found
  goHomeFlag;---- Flag to indicate that it is time to go home
  huntingFlag;---
  newFamily;----- Flag to indicate a new family
   
  
  
  homeLoc;------------home location, where the agent lives
  localxy;------------current local patch on which the agent is standing on
  
  agTimer1;---------- local timer for agents
  ;TimerX
  agAlarm1;
  dateOfDeath;------- date and time of death
  ; Proactive part
  proState ; -------- proactive state variable
  ;------------counters
  makeFriendcount ;---to limit the time to make friends
  reachFriendcount;---to limit the time to look for mutual friend
]
;******************* end local variables *****************************************************************************************************************
;**********************************************************************************************************************************************************
; SETUP FUNCTIONS
to setup-agentAs
  ; example of create-agent-function, replace with your own code!
  
  create-agentAs Number_AgentA [; Number_AgentA from slider
      set label who
      set shape "person" 
      set size 1
      set color white
      move-to one-of patches with [region = "house"]
      ; save the home location
      set homeLoc patch-here
      ;setxy [pxcor] of homeLoc [pycor] of homeLoc 
      set friend []
      set followFriend []
      set huntAgent []
      set friendList turtle-set []
      set friends ""
      set vision 2
      set fmax 7
      ; initial values of flags
      set followFlag false 
      set moveFlag false
      set proState "AtHome"
      set collectFriends false
      set visitFriend false
      set friendFound false
      set goHomeFlag false
      set huntingFlag false
      set newFamily false 
    
      set makeFriendcount 0
      set reachFriendcount 0 
    
      set dateOfDeath time:plus current-time random 72 "hour"
      
  ]
    
end ;setup-agentAs


;***************************end setup functions ******************************************************************************************************************
;************************************************************************************************************************************************************
; UPDATE information about the agent's environment

to updateEnvironmentInfo_agentAs 
  
  ; check if time is over for the agent 
  if (afterTime current-time dateOfDeath) [
    if Debug [print (word self " with dateOfDeath= " dateOfDeath " is dying now")]
    set NrDeceased NrDeceased + 1
    die]
  
  ;--- save local position
  set localxy patch-here
  

end ;updateEnvironmentInfo_agentAs
;***************************end update environment information ******************************************************************************************************************
;************************************************************************************************************************************************************
; REACTIVE SUBSUMPTION HIERARCHY
to reactive_agentAs
  ;print (word self " in reactive_agentAs")
  ; override updateEnvironmentInfo_agentAs by testcase-procedure
   if activateTestCase [override_agentASetup] ; this overrides the flags for following and moving around 
  
  ; priorities highest > lowest: go home at the end of day > move around > follow a friend
  ifelse (endOfDay or goHomeFlag) [goHome_A]
  [
    ifelse moveFlag [ moveAround_agentA]
    [
      ifelse collectFriends [addFriends]
      [
        ifelse visitFriend [followAgent]
        [
          ifelse huntingFlag [huntingAgent]
            [; unknown case, print message
             ; no reactive behavior left
             ;print (word "agentA with id: " who " has no active reactive behavior")
            ]
          ]
        ]
      ]
    ]

end ;reactive_agentAs

;---- specific reactive intention functions
to moveAround_agentA
  rt random 50
  lt random 50
  fd 1
  ; make sure the agent moves to empty region within its neighborhood
  if not (region = "empty" or region = "sanctuary") [
    let footstep neighborhood with [region = "empty"] 
    if any? footstep [move-to one-of footstep]]
end

to addFriends
  ; move around
  moveAround_agentA
  ; adds agents nearby to the friendList
  ; OBS: does not count how many that end up in the list!
  set nearbyAgents other turtles in-radius vision
  if any? nearbyAgents [
    ;print (word "agent " self " in any? nearbys" )
    set friend min-one-of nearbyAgents [distance myself]; identify the agent that is nearest
    ; make sure friend is not the agent itself
    if not (friend = self) [; only bother if it is not myself
                            ; if the list of friends is empty, add the agent
      ifelse (not any? turtle-set friendList) [set friendList friend]
      ;ifelse (empty? friendList) [set friendList friend]
      [
            ;add the friend to the friendList
            ;set friendList lput friend friendList
            set friendList (turtle-set friend friendList)
            set friends sort friendList
        ;print (word "agent " self " in added to friendList" )
      ]
          
    ]  
  ] 
end


to followAgent
  ; tries to reach the agent that is saved in followFriend
  ; does this by facing towards that friend to follow and move one step
  
  ;make sure this friend to follow still exists
  if (not any? turtle-set followFriend)[; no agent to follow, might have deceased
    ; reset the variable
    set followFriend []
    ; exit the function
    stop
  ]
  ; face towards the followFriend and move one step
  ; problem if they are on the same spot, heading will not work
  if (([list xcor ycor] of self) != ([list xcor ycor] of followFriend)) [; avoids error of not being able to use heading on same position
    set heading (towards followFriend) ;face in direction of the friend-problem if on same patch
    fd 1
  ]
  
  ; try to see if the followFriend is nearby
  set nearbyAgents other turtles in-radius vision
  if any? nearbyAgents [
    ;if (min-one-of nearbyAgents [distance myself] = followFriend)[
    if (member? followFriend nearbyAgents) [
      ; followFriend found
      set friendFound true] 
  ]
  if (Debug and followFriend != nobody) [print (word "agentA with id: " self " is trying to visit true friend with id: " [self] of followFriend)]
end

to huntingAgent
  ; agentA follows an agentB until agentB escapes into the sanctuary zone
  
  ;make sure huntAgent still exists
  if (not any? turtle-set huntAgent)[; no agent to follow, might have deceased
  ; reset the variable
    set huntAgent []
    ; exit the function
    stop
  ]
  ; face towards the huntingAgent and move one step
  ; problem if they are on the same spot, heading will not work
  if (([list xcor ycor] of self) != ([list xcor ycor] of huntAgent)) [; avoids error of not being able to use heading on same position
    set heading (towards huntAgent) ;face in direction of the friend-problem if on same patch
    fd 1
  ]
  if (Debug and huntAgent != nobody) [print (word "agentA with id: " self " is hunting agentB with id: " [self] of huntAgent)]
  
end

to goHome_A
  move-to homeLoc
  set proState "AtHome"
  set goHomeFlag false
end



;***************************end reactive subsumption hierarchy ***************************************************************************************************
;************************************************************************************************************************************************************
;************************************************************************************************************************************************************
; PROACTIVE BEHAVIOR
to proactive_agentAs
  ;deliberation between the following states
  ;-- AtHome
  ;-- MakeFriends
  ;-- VisitingFriend
  ;-- HuntingAgentB
  ;-- BuildingFamily
  ;-- (Die)
  
  ; important conditions for the deliberation decision:
  ; - if not enough friends -> MakeFriends or HuntingAgentB
  ; - if enough friends -> VisitingFriend or StayHome
  ; - if VisitingFriend -> BuildingFamily -> Die
  ;print (word self " in proactive_agentAs")
  run proState
   
end

; Proactive States

to AtHome
  if Debug [print (word "agent " self " in proState AtHome" )]
  
  ; State used for the deliberation of the other proactive states
  
  ; Preconditions
  ; - as long as the agent is in this state all the reactive flags should be reset
  set goHomeFlag false
  set moveFlag false
  set collectFriends false
  set visitFriend false
  set followFlag false
  ;------
  
  ; Intention of this state
  ; - mainly deliberation or reconsidering
  ; - no active transition is performed other than change in the proState variable
  ; - important conditions for the deliberation decision:
  ;       - if not enough friends -> MakeFriends or HuntingAgentB
  ;       - if enough friends -> VisitingFriend or stay AtHome (to receive friends?)
  ifelse (count turtle-set friendList < fmax) 
  [; not enough friends
    if Debug [print (word "agent " self " in proState AtHome-not enough friends" )]
    ifelse ((random 2) = 0) [set proState "MakeFriends"][set proState "HuntingAgentB"]
  ]
  [; enough friends
    if Debug [print (word "agent " self " in proState AtHome-enough friends" )]
    ifelse ((random 2) = 1) [set proState "VisitingFriend"][set proState "AtHome"]
  ]
  
  ; Next state deliberated
  if Debug [print (word "Next state deliberated at AtHome is proState: " proState)]
  
  ; Postconditions
  ; - none
  
end

to MakeFriends
  if Debug [print (word "agent " self " in proState MakeFriends" )]
  ; State in which the agent walks around randomly to 'collect' friends
  ; If enough friends are collected it will go and visit one of them
  ; If not enough friends can be collected in reasonable time, the
  ; agent is considered to be an 'incel' and radicalised to hunt agentBs
  
  
  ; Preconditions
  ; - as long as the agent walks around to make friends, the collectFriends flag should be set
  ; - the reactive function collectFriends activates 'movearound'
  set collectFriends true
  
  ; Intention of this state
  ; - walk around randomly, activating the reactive function 'addFriends'
  ; - addFriends walks and registers other agents closest to the agent and
  ;   puts them into the agent's friend, FriendList and friends - variable.
  ;   It also makes sure that not the agent itself is being put into the lists
  ; - The intention of this state is to check if the agent has collected enough friends or not
  ;
  ;- If enough friends are in the list, the proState switches to 'VisitingFriend'
  ifelse (count turtle-set friendList > fmax) [
    set proState "VisitingFriend"
    ; Postcondition for the end of this state:
    set collectFriends false 
    set makeFriendcount 0 ]
  [; not enough friends yet
    ; One cannot wait forever to see if the agent makes any friends
    ; some sort of counter or timestamp is needed
    ifelse (makeFriendcount = 0)[
      ;initialising the counter
      set makeFriendcount makeFriendcount + 1]
    [; test if the agent tried a critical number of times
      if (makeFriendcount > (2 * fmax)) [
        ; twice the length of friends in the list should be enough
        ; if it comes here than the agent has not found enough friends
        ; and is rather hopeless.
        ; We simulate this here as 'incels' and that turns them towards
        ; wanting to hunt agentBs
        set proState "HuntingAgentB"
        ; Postcondition for the end of this state:
        set collectFriends false 
        set makeFriendcount 0 
      ]
    ]
  ]
  ; Postconditions
  ; - handled in the different intention parts
end

to VisitingFriend
  if Debug [print (word "agent " self " in proState VisitingFriend" )]
  ; State in which the agent is looking for a friend to visit
  ; It looks for a 'true' or 'mutual' friend, e.g. a friend who has 
  ; this agent in its friendList.
  ; The agent tries to find this friend by following it. Different situations can occur:
  ; - it tries to reach the friend but does not succeed in reasonable time
  ; - it reaches the friend, but this friend is following another agent or none at all
  ; - it reaches the friend and it turns out that this friend is concurrently trying to 
  ;   reach this agent. 'Love at first sight' occurs between them.
  
  ; Precondition
  ; as long as the agent tries to visit a friend that flag needs to be set
  ;set visitFriend true ; should not be set if there are no followFriend
  
  ; Intention of this state
  ; - find a mutual friend to follow - if it can't parts of the friendlist should be removed
  ;   and next prostate becomes MakeFriends (to find mutual friends)
  ; - follow a mutual friend:
  ;                     - for some time, if it takes too long go home and rest
  ;                     - if found check if the friend is 'the right one'.
  ;                       If it is, they both switch to the proState 'BuildFamily'
  ;                       If it is not, the agent removes the friend from its list
  ;                       and goes home to rest
  ;
  
  ; Finding a 'true' friend to visit
  ; a true-friend is a mutual friend, e.g. the friend has the agent as friend
  ; Only find a friend one time when in this state
  ifelse followFriend = [] [
    ; No "for each" needed! Use a pattern-matchin by looking att all agentAs in the friendList that
    ; contain this agent in the friendList
    ; make sure that the friend in the FriendList has an own FriendList first
    ; get the list of all the agentAs from the friendList
    let friendagents turtle-set friendList with [breed = agentAs]
    set friendagents turtle-set friendagents with [friends != ""] ; removes agents without friends
    set followFriend (one-of friendagents with [member? myself friends])
    if (Debug and followFriend != nobody) [print (word self " is planning to follow " followFriend)]
    ; The intention of this state requires that a mutual friend can be found, e.g. that followFriend is not emtpy set
    ifelse (any? turtle-set followFriend)
    [
      ; mutual friend to follow found
      ; set flag to be used outside this first-time loop by the reactive function 
      set visitFriend true    
    ]
    [; no mutual friends found
      ; remove parts of the friendList and make it go out and look for better friends
      ; friendList should be fmax long, but one never knows
      if count friendList >= fmax [set friendList (n-of (round fmax / 2) friendList)]
      set proState "MakeFriends" ;
      set visitFriend false
      set friendFound false  ; unclear if needed here
      set followFriend []
    ]
  ]; end followFriend = []
  [; mutual friend exists and the agent tries to reach it
    ; starting a timer to decide when to stop trying reaching it
    ifelse (reachFriendcount = 0)[
      ;initialising the counter
      set reachFriendcount reachFriendcount + 1]
    [
      ; make sure the followFriend still exists, otherwise exit
      if followFriend = nobody [
        ; friend probably deceased
        set followFriend  []
        set friendFound false
        stop]
      
      ; if the followFriend is found in the reactive function it will set the flag friendFound
      ifelse friendFound [
        ; friend is found, test if it is the 'right' one
        ifelse ([followFriend] of followFriend = self) [
          ; mutual friends found each other at the same time!
          set color red
          ask followFriend [set color red]
          set proState "BuildingFamily"
          set visitFriend false
          set friendFound false 
        ]
        [; not really a mutual friend
         ;The agent removes the friend from its list and goes home to rest
          ;test
          ;print (word self ": friendList= " sort friendList ", followFriend = " followFriend)
          ;print (word "not member followFriend in friendList1= " (not member? followFriend friendList))
          ;print (word "not member followFriend in friendList2= " sort friendList who-are-not followFriend)
          
          set friendList friendList who-are-not followFriend
          set goHomeFlag true;
          set proState "AtHome"
          set followFriend []
          set visitFriend false
        ]
      ]
      [
      ; friend not yet found
      ; decide if it should keep on looking longer or stop
      if reachFriendcount > 50 [; more or less random threshold
        ; stop looking for the friend, go home and rest
        set proState "AtHome" ;
        set visitFriend false
        set goHomeFlag true
      ]
    ]
  ]

  ]

end

to HuntingAgentB
  if Debug [print (word "agent " self " in proState HuntingAgentB" )]
  
  ; State in which the agentA is stalking an agentB and follows this agent until it escapes 
 
  
  ; Precondition
  ; agentA needs to be able to find an agentB in its friendList
  ; make sure that only happens once
  if huntAgent = [] [
    ; make sure not everybody in the friendList died
    if friendList = nobody [stop]
    ifelse (any? friendList with [breed = agentBs])
    [
      ; select one agentB
      set huntAgent (one-of friendList with [breed = agentBs])
      set huntingFlag true
    ]
    [
      ;no agentB to follow
      set huntingFlag false
      ; go out and make some more friends
      ; keep some friends only
      ; either the friendlist is too long and needs shortening or it is empty
      if friendList != [] [
        if count friendList > fmax [set friendList (n-of (round fmax / 2) friendList)]]
      set proState "MakeFriends"
      set huntingFlag false
    ]
  ]
  
  ; test if huntAgent has diseased
  if huntAgent = nobody [
    set huntAgent []
    set huntingFlag false
    stop
  ]
  
  ; Terminal condition for the hunt is whether agentB has escaped
  if (huntAgent != []) [
    ;test
    ;print (word "region of huntAgent= " ([region] of huntAgent))
    if ([region] of huntAgent = "sanctuary") [; stop the hunt, go home
      set proState "AtHome"
      set huntingFlag false
      set goHomeFlag true
  ]
  ]
    
end

to BuildingFamily
  if (Debug and followFriend != nobody) [print (word "agent " self " and agent " [self] of followFriend " are building family")]
  ;Precondition
  ; two agentAs have had each other as mutual friend that they were visiting at the same time
  ;
  ; Intention of this state
  ; - build a common house together in which both agentAs move into. This becomes their new home
  ;   One can discuss whether the building of a new home should be part of the reactive part and not the proactive
  ;   However, it turns out to be much easier and more straight forward to integrate it into the proactive part
  ; - both agents will never leave the home again
  ; - hatch one offspring that becomes a normal agentA
  
  ; Use the flag newFamily to determine first time in this state
  ifelse newFamily = false [
    set newFamily true
    ;set buildNewHome true
    ; add a new house into the environment
    let emptyPatches patches with [region = "empty"]
    let newHouse one-of emptyPatches
    ask newHouse [
      set region "newhouse"
      set pcolor red
    ]
    move-to newHouse
    set homeLoc patch-here
    ; test if the followFriend still lives
    if followFriend != nobody [
    ask followFriend [
      move-to newHouse
      set homeLoc patch-here
      ]
    
    ; hatch an offspring
    hatch 1 [
      ; initialize the agentA offspring
      set label who
      set shape "person" 
      set size 1
      set color 85
      move-to newHouse
      ; save the home location
      set homeLoc patch-here
      ;setxy [pxcor] of homeLoc [pycor] of homeLoc 
      set friend []
      set followFriend []
      set huntAgent []
      set friendList turtle-set []
      set vision 2
      set fmax 7
      ; initial values of flags
      set followFlag false 
      set moveFlag false
      set proState "AtHome"
      set collectFriends false
      set visitFriend false
      set friendFound false
      set goHomeFlag false
      set huntingFlag false
      set newFamily false 
    
      set makeFriendcount 0
      set reachFriendcount 0 
      set dateOfDeath time:plus current-time random 72 "hour"
      ]
    ]
  ]
  [
    ; family lives already in new home, does not need to build one more
    set buildNewHome false
    ; stays here forever until the agents die.
  ]
  
end


