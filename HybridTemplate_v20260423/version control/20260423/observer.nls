;-------------------------------------------------------------------------------------------------------------------------------------------------------
; reporters used in the plot function by the monitor-windows 

; reporter to calculate the number of free moving agentAs
to-report movingAgentAs
  let mvA (count agentAs with [moveFlag = true])
  report mvA
end



; reporter to calculate the number of free moving agentBs
to-report movingAgentBs
  let mvB (count agentBs with [state = "State_MoveAround"])
  report mvB
end

;--------------------------------------------------------- end reporters used in the plot functions --------------------------------------------------
;------------------- Reporter function regarding the environment
;
to removeHouses
  ; remove empty houses, e.g. houses were all inhabitants have died
  ; find the houses of all the living agents
  let houses patch-set [homeloc] of turtles
  ; identify all the patches with the region for houses and find out which ones are not part of 'houses'
  let emptyHouses ((patches with [(region = "house") or (region = "newhouse")]) who-are-not  houses)
  if any? emptyHouses [
    ;print (word "in removeHouses = " emptyHouses)
    ;print (word "houses that are not empty: " houses)
    ;print (word "empty houses: " emptyHouses)
    ask emptyHouses [set region "empty"
    set pcolor black]    
  ]
end
