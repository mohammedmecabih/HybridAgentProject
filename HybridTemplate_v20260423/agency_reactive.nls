
;; Reactive agency layer:
;; 1. Handles incoming FIPA-like messages once per agency tick.
;; 2. Moves the house to viral posts with post-extremity between 3 and 6.
;; 3. Inspects each post-agent exactly once, not each bot.
;; 4. If the same bot creates a new viral 3-6 post later, that new post is inspected too.
;; 5. Removes 70% of inspected viral 3-6 posts and releases 30%.
;; 6. Human-request inspections can inspect posts outside 3-6.
;; 7. Human-request decisions use 10% remove and 90% release.
;; 8. Human-request decisions are stored per post-id and reused for later requests.


to update-agency-reactive
  handle-agency-messages

  set inspected-posts filter [p -> is-agent? p] inspected-posts

  if is-agent? current-post-target [
    if not valid-agency-post-target? current-post-target [
      set current-post-target nobody
    ]
  ]

  if not is-agent? current-post-target [
    let targets posts with [
      not post-removed? and
      post-viral? and
      post-shares >= viral-share-threshold and
      post-likes >= viral-like-threshold and
      post-extremity >= 3 and
      post-extremity <= 6 and
      not member? self [inspected-posts] of myself
    ]

    if any? targets [
      set current-post-target max-one-of targets [post-id]

      log-agency (word "AGENCY " who
        " | TARGET FOUND: moving to post P" [post-id] of current-post-target
        " extremity=" [post-extremity] of current-post-target
        " shares=" [post-shares] of current-post-target
        " likes=" [post-likes] of current-post-target ".")
    ]
  ]

  if is-agent? current-post-target [
    face current-post-target

    let agency-speed 0.25

    ifelse distance current-post-target > 1.5 [
      face current-post-target

      ifelse can-move? agency-speed [
        fd agency-speed
      ] [
        rt 30
      ]
    ] [
      inspect-extreme-post current-post-target
      set current-post-target nobody
    ]

    stop
  ]

  agency-search-movement
end


to agency-search-movement
  rt ((random 61) - 30)

  ifelse can-move? 0.35 [
    fd 0.35
  ] [
    rt 180
    if can-move? 0.35 [
      fd 0.35
    ]
  ]
end


to log-agency [message-text]
  output-print message-text
  print message-text
end


to handle-agency-messages
  let incoming-msg get-message
  let safety-counter 0

  while [incoming-msg != "no_message" and safety-counter < 20] [
    set safety-counter safety-counter + 1

    let performative get-performative incoming-msg
    let content get-content incoming-msg
    let msg-sender get-sender incoming-msg

    log-agency (word "AGENCY " who
      " | FIPA RECEIVED: sender=" msg-sender
      " performative=" performative
      " content=" content)

    if is-list? content and length content >= 2 and item 0 content = "investigating" [
      let busy-bot-id item 1 content

      if is-number? busy-bot-id and turtle busy-bot-id != nobody [
        if not member? busy-bot-id busy-bot-ids [
          set busy-bot-ids lput busy-bot-id busy-bot-ids

          log-agency (word "AGENCY " who
            " | COORDINATION: bot " busy-bot-id
            " marked busy because another agency is investigating it.")
        ]
      ]

      if is-agent? investigation-target and [who] of investigation-target = busy-bot-id [
        if member? proState_agency ["Monitoring" "Investigating"] [
          set investigation-target nobody
          set investigation-ticks 0
          set delegated-target nobody
          set delegated-action "none"
          set has-delegation? false
          set proState_agency "Monitoring"

          log-agency (word "AGENCY " who
            " | COORDINATION: stopped own investigation of bot "
            busy-bot-id
            " because agency " msg-sender
            " already handles it.")
        ]
      ]
    ]

    if performative = "request" [
      let sender-agent sender-as-agent msg-sender
      let sender-is-human? false

      if is-agent? sender-agent [
        if [breed] of sender-agent = humans [
          set sender-is-human? true
        ]
      ]

      if sender-is-human? [
        let reply create-message "confirm"
        set reply add-receiver msg-sender reply
        set reply add-content (list "request-received" content) reply
        send reply

        log-agency (word "AGENCY " who
          " | FIPA SENT confirm to human " msg-sender
          ": request received.")

        ifelse is-list? content and length content >= 2 and item 0 content = "investigate-post" [
          let requested-value item 1 content

          let old-decision get-human-request-decision requested-value

          ifelse old-decision != false [
            send-stored-human-request-result msg-sender old-decision

            log-agency (word "AGENCY " who
              " | HUMAN REQUEST RESULT: reused stored decision for post P"
              requested-value ".")
          ] [
            let requested-post resolve-requested-post requested-value sender-agent

            ifelse is-agent? requested-post [
              inspect-human-request-post requested-post msg-sender
            ] [
              let result-msg create-message "inform"
              set result-msg add-receiver msg-sender result-msg
              set result-msg add-content
                (list "investigation-complete" "post-not-found" requested-value)
                result-msg
              send result-msg

              log-agency (word "AGENCY " who
                " | FIPA SENT inform to human " msg-sender
                ": investigation complete, no valid post found for "
                requested-value ".")
            ]
          ]
        ] [
          let result-msg create-message "inform"
          set result-msg add-receiver msg-sender result-msg
          set result-msg add-content
            (list "investigation-complete" "unsupported-request" content)
            result-msg
          send result-msg

          log-agency (word "AGENCY " who
            " | FIPA SENT inform to human " msg-sender
            ": unsupported request.")
        ]
      ]
    ]

    if performative = "inform" [
      let sender-agent sender-as-agent msg-sender
      let sender-is-human? false

      if is-agent? sender-agent [
        if [breed] of sender-agent = humans [
          set sender-is-human? true
        ]
      ]

      if sender-is-human? [
        if is-list? content and not empty? content [
          if item 0 content = "suspicious-topic" or item 0 content = "warning" [
            set numberOfReports numberOfReports + 1
          ]
        ]

        let reply create-message "confirm"
        set reply add-receiver msg-sender reply
        set reply add-content (list "inform-received" content) reply
        send reply

        log-agency (word "AGENCY " who
          " | FIPA SENT confirm to human " msg-sender
          ": inform received. numberOfReports=" numberOfReports ".")
      ]
    ]

    set incoming-msg get-message
  ]
end


to inspect-extreme-post [target]
  if not is-agent? target [ stop ]

  if [post-removed?] of target [ stop ]
  if not [post-viral?] of target [ stop ]
  if [post-shares] of target < viral-share-threshold [ stop ]
  if [post-likes] of target < viral-like-threshold [ stop ]
  if [post-extremity] of target < 3 [ stop ]
  if [post-extremity] of target > 6 [ stop ]

  if not member? target inspected-posts [
    set inspected-posts lput target inspected-posts
  ]

  log-agency (word "AGENCY " who
    " | POST INSPECTION: post P" [post-id] of target
    " origin=" [who] of [post-origin] of target
    " shares=" [post-shares] of target
    " likes=" [post-likes] of target
    " extremity=" [post-extremity] of target ".")

  let slump-tal (random 100) + 1

  ifelse slump-tal <= 50 [
    let removed-post-id [post-id] of target

    log-agency (word "AGENCY " who
      " | DECISION: post P" removed-post-id
      " roll=" slump-tal
      " -> REMOVED.")

    ask target [
      set post-removed? true
      set post-viral? false
      set post-shares 0
      set post-likes 0
      set label "REMOVED"
      set size 0
      hide-turtle
    ]

    set corrections-published corrections-published + 1

    if any? humans [
      let msg create-message "inform"
      set msg add-content (list "post-removed" removed-post-id) msg
      broadcast-to humans msg who

      log-agency (word "AGENCY " who
        " | FIPA SENT inform to humans: post P"
        removed-post-id
        " was removed.")
    ]

    display
  ] [
    let released-post-id [post-id] of target

    log-agency (word "AGENCY " who
      " | DECISION: post P" released-post-id
      " roll=" slump-tal
      " -> RELEASED.")

    ask target [
      set label "RELEASED"
    ]

    if any? humans [
      let msg create-message "inform"
      set msg add-content (list "post-released" released-post-id) msg
      broadcast-to humans msg who

      log-agency (word "AGENCY " who
        " | FIPA SENT inform to humans: post P"
        released-post-id
        " was released.")
    ]

    rt 90
    if can-move? 0.4 [
      fd 0.4
    ]
  ]
end


to inspect-human-request-post [target requester-id]
  if not is-agent? target [ stop ]
  if [breed] of target != posts [ stop ]
  if [post-removed?] of target [ stop ]

  ;; Ingen 3-6-spärr här.
  ;; Human-request får utreda även posts utanför 3-6.
  ;; Viktigt: human-request ska inte lägga posten i inspected-posts.
  ;; inspected-posts används bara av automatiska 3-6-systemet.

  let target-post-id [post-id] of target
  let target-extremity [post-extremity] of target

  log-agency (word "AGENCY " who
    " | HUMAN REQUEST INSPECTION: post P" target-post-id
    " topic=" [post-topic] of target
    " extremity=" target-extremity
    " shares=" [post-shares] of target
    " likes=" [post-likes] of target ".")

  let decision random 100

  ifelse decision < 10 [
    log-agency (word "AGENCY " who
      " | HUMAN REQUEST DECISION: post P" target-post-id
      " extremity=" target-extremity
      " roll=" decision
      " -> REMOVED.")

    ask target [
      set post-removed? true
      set post-viral? false
      set post-shares 0
      set post-likes 0
      set label "REMOVED"
      set size 0
      hide-turtle
    ]

    set corrections-published corrections-published + 1

    if get-human-request-decision target-post-id = false [
      set human-request-decisions
        (lput (list target-post-id "post-removed" target-extremity)
        human-request-decisions)
    ]

    let result-msg create-message "inform"
    set result-msg add-receiver requester-id result-msg
    set result-msg add-content
      (list "investigation-complete" "post-removed" target-post-id target-extremity)
      result-msg
    send result-msg

    log-agency (word "AGENCY " who
      " | FIPA SENT inform to human " requester-id
      ": investigation complete, post P"
      target-post-id
      " removed.")
  ] [
    log-agency (word "AGENCY " who
      " | HUMAN REQUEST DECISION: post P" target-post-id
      " extremity=" target-extremity
      " roll=" decision
      " -> RELEASED.")

    ask target [
      set label "RELEASED"
    ]

    if get-human-request-decision target-post-id = false [
      set human-request-decisions
        (lput (list target-post-id "post-released" target-extremity)
        human-request-decisions)
    ]

    let result-msg create-message "inform"
    set result-msg add-receiver requester-id result-msg
    set result-msg add-content
      (list "investigation-complete" "post-released" target-post-id target-extremity)
      result-msg
    send result-msg

    log-agency (word "AGENCY " who
      " | FIPA SENT inform to human " requester-id
      ": investigation complete, post P"
      target-post-id
      " released.")
  ]
end


to-report resolve-requested-post [requested-value sender-human]
  if is-number? requested-value [
    let exact-post one-of posts with [
      post-id = requested-value and
      not post-removed?
    ]

    if is-agent? exact-post [
      report exact-post
    ]
  ]

  if is-agent? sender-human [
    if [breed] of sender-human = humans [
      let sender-post [currentPost] of sender-human

      if is-agent? sender-post [
        if [breed] of sender-post = posts and not [post-removed?] of sender-post [
          report sender-post
        ]
      ]
    ]
  ]

  if is-string? requested-value [
    let topic-posts posts with [
      post-topic = requested-value and
      not post-removed?
    ]

    if any? topic-posts [
      report max-one-of topic-posts [post-id]
    ]
  ]

  report nobody
end


to-report get-human-request-decision [requested-post-id]
  if not is-number? requested-post-id [
    report false
  ]

  let found-decision false

  foreach human-request-decisions [decision-record ->
    if found-decision = false [
      if item 0 decision-record = requested-post-id [
        set found-decision decision-record
      ]
    ]
  ]

  report found-decision
end


to send-stored-human-request-result [receiver-id decision-record]
  let saved-post-id item 0 decision-record
  let saved-result item 1 decision-record
  let saved-extremity item 2 decision-record

  let result-msg create-message "inform"
  set result-msg add-receiver receiver-id result-msg
  set result-msg add-content
    (list "investigation-complete" saved-result saved-post-id saved-extremity)
    result-msg
  send result-msg
end


to-report sender-as-agent [sender-value]
  if is-number? sender-value [
    if turtle sender-value != nobody [
      report turtle sender-value
    ]
  ]

  if is-string? sender-value [
    let parsed nobody

    carefully [
      set parsed read-from-string sender-value
    ] [
      set parsed nobody
    ]

    if is-number? parsed [
      if turtle parsed != nobody [
        report turtle parsed
      ]
    ]
  ]

  report nobody
end


to-report valid-agency-post-target? [p]
  if not is-agent? p [ report false ]
  if [breed] of p != posts [ report false ]

  if [post-removed?] of p [ report false ]
  if not [post-viral?] of p [ report false ]
  if [post-shares] of p < viral-share-threshold [ report false ]
  if [post-likes] of p < viral-like-threshold [ report false ]
  if [post-extremity] of p < 3 [ report false ]
  if [post-extremity] of p > 6 [ report false ]
  if member? p inspected-posts [ report false ]

  report true
end