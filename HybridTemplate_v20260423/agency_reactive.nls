; Agency Reactive

to update-agency-reactive
  ;; === KOMMUNIKATION: LÄS BREVLÅDAN FÖRST ===
  handle-agency-messages

  ;; Myndigheten scannar efter inlägg baserat på era faktiska modellvariabler:
  ;; 1. Ska inte redan vara borttaget (post-removed? = false)
  ;; 2. Ska ha nått tröskelvärdet för att vara viralt (både shares och likes)
  ;; 3. Ska ligga inom det måttliga/gula extremism-intervallet (> 3 och <= 6)
  ;; 4. Ska inte redan ha godkänts/inspekterats av denna myndighet tidigare
  
  let targets posts with [
    not post-removed? and 
    post-shares >= viral-share-threshold and 
    post-likes >= viral-like-threshold and 
    post-extremity > 3 and 
    post-extremity <= 6 and 
    not member? self [inspected-posts] of myself
  ]
  
  if any? targets [
    let closest-target min-one-of targets [distance myself]
    face closest-target
    fd 0.5
    if distance closest-target < 1.5 [
      handle-target-action closest-target
    ]
  ]
end

;; === PROCEDUR FÖR ATT HANTERA INKOMMANDE MEDDELANDEN ===
to handle-agency-messages
  ;; Hämta det första meddelandet i kön
  let incoming-msg get-message
  
  ;; Loopa igenom alla meddelanden som ligger i kön just nu
  while [incoming-msg != "no_message"] [
    
    let content get-content incoming-msg
    let msg-sender get-sender incoming-msg
    
    ;; Samordning: Om en kollega utreder en bot, avbryt om vi gör samma sak
    if member? "investigating:" content [
      let busy-bot-id read-from-string remove "investigating:" content
      
      if investigation-target != nobody and [who] of investigation-target = busy-bot-id [
        if proState_agency = "Monitoring" or proState_agency = "Investigating" [
          set investigation-target nobody
          set proState_agency "Monitoring"
          output-print (word "COORDINATION: Agency " who " avbryter utredning av bot " busy-bot-id " eftersom kollega " msg-sender " redan hanterar den.")
        ]
      ]
    ]
    
    ;; Gå till nästa meddelande i kön
    set incoming-msg get-message 
  ]
end

;; === PROCEDUR FÖR ATT FATTA BESLUT OM INLÄGG ===
to handle-target-action [target]
  ;; Slumpa en siffra mellan 1 och 100
  let slump-tal (random 100) + 1
  
  ifelse slump-tal > 50 [
    ;; --- FALL A: RADERA ---
    output-print (word "AGENCY: Siffra " slump-tal " - Raderar inlägg (Extremity: " [post-extremity] of target ") och går vidare.")
    ask target [ die ] 
  ] [
    ;; --- FALL B: SLÄPP (Här slipper vi gruppens globala "Removed"-text) ---
    output-print (word "AGENCY: Siffra " slump-tal " - Släpper inlägg och letar nästa.")
    
    ;; Spara inlägget i myndighetens interna minne
    set inspected-posts lput target inspected-posts
  ]
end