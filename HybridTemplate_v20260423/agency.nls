; Agency thresholds (koppla till sliders i UI)
;bot-frequency-threshold 
;viral-crisis-threshold 
;report-crisis-threshold 
;report-flag-threshold

; LOGBOOK OF UPDATES IN THIS FILE
; --Date--- |----Description-----------------------------------
; 20260428  v1.0  Agency hybrid agent: reactive + proactive layers (Rayyan)
; 20260428  v1.1  Delegation channel between proactive and reactive (Rayyan)
;***************************************************************

; ── Agency-specific variables ──────────────────────────────────
agencies-own [
  ; Proactive FSM state
  proState_agency

  ; Investigation memory
  investigation-target
  investigation-ticks

  ; Counters
  bans-issued
  corrections-published

  ; Delegation channel (proactive → reactive)
  delegated-action
  delegated-target
  has-delegation?

  ; Reactive one-action-per-tick guard
  reactive-acted?
]

; ── Setup ───────────────────────────────────────────────────────
to setup-agencies
  create-agencies 1 [
    set shape "square"
    set color white
    set size 3
    setxy 0 0

    ; Template var
    set beliefs        []
    set intentions     []
    set incoming-queue []

    ; Agency FSM
    set proState_agency      "Monitoring"
    set investigation-target  nobody
    set investigation-ticks   0
    set bans-issued           0
    set corrections-published 0

    ; Delegation channel
    set delegated-action "none"
    set delegated-target nobody
    set has-delegation?  false

    set reactive-acted? false
    
  
  ]
end

; ── Called every tick from go ────────────────────────────────────
to updateEnvironmentInfo_agencies
  ; Agency reads shared globals written by humans + bots
  ; (numberOfReports, viralTrend, totalShares are already updated by humans)
  set reactive-acted? false
end

; ══════════════════════════════════════════════════════════════════
;  REACTIVE LAYER  (subsumption — highest priority first)
; ══════════════════════════════════════════════════════════════════
to reactive_agencies

  ; Priority 0 — execute any pending delegation from proactive layer
  if has-delegation? [
    execute-delegation
    set reactive-acted? true
    stop
  ]

  ; Priority 1 — Ban bots 
  if viralTrend > viral-crisis-threshold and numberOfReports > report-crisis-threshold [
    let worst-bot max-one-of (agentBs with [is-banned? = false]) [post-frequency]
    if worst-bot != nobody [
      ask worst-bot [ set is-banned? true set color black ]
      set bans-issued bans-issued + 1
      output-print (word "REACTIVE P1: viral crisis — emergency ban on bot " [who] of worst-bot)
      set reactive-acted? true
      stop
    ]
  ]

  ; Priority 2 — flag human posts if report threshold 
  if numberOfReports > report-flag-threshold [
    let target one-of (humans with [
      is-infected? = true and is-resistant? = false and is-banned? = false
    ])
    if target != nobody [
      ask target [
        set is-infected?  false
        set is-resistant? true
        set color green
      ]
      set corrections-published corrections-published + 1
      output-print (word "REACTIVE P2: report threshold — corrected human " [who] of target)
      set reactive-acted? true
      stop
    ]
  ]

  ; Priority 3 — passive scan (lowest looking at keywords. 
  output-print (word
    "REACTIVE P3: monitoring — reports=" numberOfReports
    " viralTrend=" viralTrend
    " bans=" bans-issued
    " corrections=" corrections-published)
end

; ══════════════════════════════════════════════════════════════════
;  PROACTIVE LAYER  Monitoring , Investigating , Deciding ,  Reporting)
; ══════════════════════════════════════════════════════════════════
to proactive_agencies
  if proState_agency = "Monitoring"     [ agency-monitoring     stop ]
  if proState_agency = "Investigating"  [ agency-investigating  stop ]
  if proState_agency = "Deciding"       [ agency-deciding       stop ]
  if proState_agency = "Reporting"      [ agency-reporting      stop ]
end

; ── Monitoring: wait for a signal worth investigating ────────────
to agency-monitoring
  output-print "PROACTIVE [Monitoring]"

  ; Trigger investigation if bots are active OR disinformation is spreading
  if any? agentBs with [is-banned? = false and post-frequency > bot-frequency-threshold] [
    set investigation-target one-of agentBs with [
      is-banned? = false and post-frequency > bot-frequency-threshold
    ]
    set investigation-ticks 0
    set proState_agency "Investigating"
    output-print (word "PROACTIVE [Monitoring→Investigating]: target = " [who] of investigation-target)
    stop
  ]

  if numberOfReports > report-flag-threshold [
    ; Investigate the most-reported human (approximated: most infected)
    let candidate one-of (humans with [is-infected? = true and is-banned? = false])
    if candidate != nobody [
      set investigation-target candidate
      set investigation-ticks 0
      set proState_agency "Investigating"
      output-print (word "PROACTIVE [Monitoring→Investigating]: suspicious human " [who] of investigation-target)
    ]
  ]
end

; ── Investigating: gather ticks of evidence before deciding ─────
to agency-investigating
  output-print (word "PROACTIVE [Investigating]: tick " investigation-ticks)

  ; Guard: target disappeared or was already handled
  if investigation-target = nobody [
    set proState_agency "Monitoring" stop
  ]
  if [is-banned?] of investigation-target [
    set investigation-target nobody
    set proState_agency "Monitoring" stop
  ]

  set investigation-ticks investigation-ticks + 1

  ; After enough evidence ticks, move to deciding
  if investigation-ticks >= 2 [
    set proState_agency "Deciding"
    output-print "PROACTIVE [Investigating→Deciding]"
  ]
end

; ── Deciding: ────────────────────
to agency-deciding
  output-print "PROACTIVE [Deciding]"

  if investigation-target = nobody [
    set proState_agency "Monitoring" stop
  ]
  if [is-banned?] of investigation-target [
    set investigation-target nobody
    set proState_agency "Monitoring" stop
  ]

  ; Bot confirmed then full ban
  if [breed] of investigation-target = agentBs and
     [post-frequency] of investigation-target > bot-frequency-threshold and
     [account-age] of investigation-target < 8 [
    set delegated-action "full-ban"
    set delegated-target investigation-target
    set has-delegation? true
    output-print (word "PROACTIVE [Deciding]: delegating full-ban → " [who] of investigation-target)
    set proState_agency "Reporting"
    stop
  ]

  ; propaganda human then correction
  if [breed] of investigation-target = humans and
     [is-infected?] of investigation-target and
     not ([is-resistant?] of investigation-target) [
    set delegated-action "publish-correction"
    set delegated-target investigation-target
    set has-delegation? true
    output-print (word "PROACTIVE [Deciding]: delegating correction → " [who] of investigation-target)
    set proState_agency "Reporting"
    stop
  ]

  ; Nothing decisive yet — back to monitoring
  output-print "PROACTIVE [Deciding]: inconclusive, back to Monitoring"
  set proState_agency "Monitoring"
end

; ── Reporting: log outcome, reset, loop back ────────────────────
to agency-reporting
  output-print (word
    "PROACTIVE [Reporting]: bans=" bans-issued
    " corrections=" corrections-published)
  set investigation-target nobody
  set investigation-ticks   0
  set proState_agency "Monitoring"
end

; ══════════════════════════════════════════════════════════════════
; Delegation
; ══════════════════════════════════════════════════════════════════
to execute-delegation

  if delegated-action = "full-ban" and delegated-target != nobody [
    if not ([is-banned?] of delegated-target) [
      ask delegated-target [ set is-banned? true set color black ]
      set bans-issued bans-issued + 1
      output-print (word "DELEGATION: full-ban executed on " [who] of delegated-target)
    ]
  ]

  if delegated-action = "publish-correction" and delegated-target != nobody [
    if not ([is-banned?] of delegated-target) [
      ask delegated-target [
        set is-infected?  false
        set is-resistant? true
        set color green
      ]
      ; Correctio
      ask [link-neighbors] of delegated-target [
        if not is-banned? and not is-resistant? [
          if random 100 < 40 [
            set is-infected?  false
            set is-resistant? true
          ]
        ]
      ]
      set corrections-published corrections-published + 1
      output-print (word "DELEGATION: correction published at " [who] of delegated-target)
    ]
  ]

  ; Clear channel
  set delegated-action "none"
  set delegated-target nobody
  set has-delegation?  false
end 
