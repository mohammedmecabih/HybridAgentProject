
; Agency Proactive

;; Proactive agency FSM.
;; Rules implemented here:
;; - Total bots can be changed from the NetLogo slider/setup.
;; - Agency may ban only 10% of the bots created at setup.
;; - Original bot count is reconstructed as: count agentBs + total-banned-bots.
;; - Bots are suspicious only if they created at least one viral post with post-extremity 3-6.
;; - Banning happens gradually while the simulator runs.
;; - Uses variables only, not display color.
;; - Uses FIPA-like communication methods already used in the project.

to update-agency-proactive
  ;; Keep coordination memory clean: remove ids for agents that no longer exist.
  set busy-bot-ids filter [id -> is-number? id and turtle id != nobody] busy-bot-ids

  ifelse proState_agency = "Monitoring" [ agency-monitoring ]
  [ ifelse proState_agency = "Investigating" [ agency-investigating ]
    [ ifelse proState_agency = "Deciding" [ agency-deciding ]
      [ if proState_agency = "Reporting" [ agency-reporting ] ]]]
end


to agency-monitoring
  ;; Leta efter virala posts som inte redan är borttagna.
  ;; Viktigt: posts skapas av agentA, inte av agentB.
let viral-posts posts with [
  not post-removed? and
  post-viral? and
  post-shares >= viral-share-threshold and
  post-likes >= viral-like-threshold and
  not member? self [inspected-posts] of myself
]

  if any? viral-posts [
    let target max-one-of viral-posts [post-id]

    set investigation-target target
    set investigation-ticks 0
    set proState_agency "Investigating"

    log-agency (word "AGENCY " who
      " | MONITORING: Found viral post P"
      [post-id] of target
      " origin=" [who] of [post-origin] of target
      " shares=" [post-shares] of target
      " likes=" [post-likes] of target
      ".")
  ]
end


to agency-investigating
  if not is-agent? investigation-target [
    log-agency (word "AGENCY " who " | INVESTIGATING: target no longer exists. Resetting.")
    reset-agency-investigation
    stop
  ]

  if [breed] of investigation-target != posts [
    log-agency (word "AGENCY " who " | INVESTIGATING: target is not a post. Resetting.")
    reset-agency-investigation
    stop
  ]

  set investigation-ticks investigation-ticks + 1

  log-agency (word "AGENCY " who
    " | INVESTIGATING: post P"
    [post-id] of investigation-target
    " tick " investigation-ticks " / 3.")

  if investigation-ticks >= 3 [
    set proState_agency "Deciding"
  ]
end


to agency-deciding
  if not is-agent? investigation-target [
    reset-agency-investigation
    stop
  ]

  if [breed] of investigation-target != posts [
    reset-agency-investigation
    stop
  ]

  ifelse [post-viral?] of investigation-target and not [post-removed?] of investigation-target [
    set delegated-action "remove-viral-post"
    set delegated-target investigation-target

    log-agency (word "AGENCY " who
      " | DECIDING: decision = REMOVE post P"
      [post-id] of investigation-target ".")
  ] [
    set delegated-action "none"
    set delegated-target nobody
  ]

  set has-delegation? true
  set proState_agency "Reporting"
end


to agency-reporting
  log-agency (word "AGENCY " who " | REPORTING: executing action = " delegated-action ".")

  if has-delegation? [
    execute-delegation
  ]

  log-agency (word "AGENCY " who " | REPORTING: completed. Returning to MONITORING.")
  reset-agency-investigation
end


to execute-delegation
  if delegated-action = "none" [
    set has-delegation? false
    stop
  ]

    if delegated-action = "remove-viral-post" [
    if is-agent? delegated-target [
      if [breed] of delegated-target = posts [
        let target-post delegated-target
        let target-post-id [post-id] of target-post
        let slump-tal (random 100) + 1
        
        if not member? target-post inspected-posts [
        set inspected-posts lput target-post inspected-posts
         ]

        ifelse slump-tal <= 50 [
          ask target-post [
            set post-removed? true
            set post-viral? false
            set post-shares 0
            set post-likes 0
            set label "REMOVED"
            set size 0
            hide-turtle
          ]

          set corrections-published corrections-published + 1

          log-agency (word "AGENCY " who
            " | PROACTIVE DECISION: post P" target-post-id
            " roll=" slump-tal
            " -> REMOVED.")

          if any? humans [
            let msg create-message "inform"
            set msg add-content (list "post-removed" target-post-id) msg
            broadcast-to humans msg who
          ]
        ] [
          ask target-post [
            set label "RELEASED"
          ]

          log-agency (word "AGENCY " who
            " | PROACTIVE DECISION: post P" target-post-id
            " roll=" slump-tal
            " -> RELEASED.")

          if any? humans [
            let msg create-message "inform"
            set msg add-content (list "post-released" target-post-id) msg
            broadcast-to humans msg who
          ]
        ]
      ]
    ]

    set delegated-action "none"
    set delegated-target nobody
    set has-delegation? false
    stop
  ]

  set delegated-action "none"
  set delegated-target nobody
  set has-delegation? false
end


to reset-agency-investigation
  if is-agent? investigation-target [
    set busy-bot-ids remove [who] of investigation-target busy-bot-ids
  ]

  set investigation-target nobody
  set investigation-ticks 0
  set delegated-target nobody
  set delegated-action "none"
  set has-delegation? false
  set proState_agency "Monitoring"
end


to-report is-suspicious-bot? [candidate]
  if not is-agent? candidate [ report false ]
  if [breed] of candidate != agentBs [ report false ]
  if [hidden?] of candidate [ report false ]
  if [is-banned?] of candidate [ report false ]

  report any? posts with [
    post-origin = candidate and
    not post-removed? and
    post-viral? and
    post-shares >= viral-share-threshold and
    post-likes >= viral-like-threshold and
    post-extremity >= 3 and
    post-extremity <= 6
  ]
end


to-report total-banned-bots
  ;; bans-issued is agency-owned, so sum over all agencies.
  report sum [bans-issued] of agencies
end


to-report original-bot-count
  ;; Reconstruct the setup count:
  ;; alive bots + bots already banned by agencies.
  report count agentBs + total-banned-bots
end


to-report max-bots-to-ban
  if original-bot-count <= 0 [ report 0 ]
  report ceiling (original-bot-count * 0.10)
end


to-report remaining-ban-slots
  let slots max-bots-to-ban - total-banned-bots
  if slots < 0 [ report 0 ]
  report slots
end
