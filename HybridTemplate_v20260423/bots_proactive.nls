; BESKRIVNING AV FILEN

; Den här filen beskriver den proaktiva huvudbotten, agentA.
; Den proaktiva botten är ansvarig för att skapa inlägg, sprida dem till reaktiva bottar,
; skicka request-meddelanden till humans, övervaka om inlägg blir virala eller borttagna,
; och skapa liknande inlägg efter viralitet eller borttagning.
;
; Agenten är en hybrid agent:
; - Den proaktiva delen använder FSM-state, till exempel BotCreatePost, EvaluateBotPost,
;   BotMonitorRemoval och BotGenerateSimilarPost.
; - Den reaktiva delen utför konkreta handlingar via flaggor, till exempel createPostFlag,
;   broadcastPostFlag och generateSimilarPostFlag.
;
; Agenten kommunicerar också socialt:
; - inform till agentBs när ett nytt inlägg finns
; - request till humans för att promota ett inlägg
; - tar emot agree/refuse från human
;*********************************************************************************************************************************************************

breed [posts post]

posts-own [
  post-id post-topic post-extremity post-shares post-likes
  post-viral? post-removed? post-origin parent-post-id post-age
]

agentAs-own [
  homeLoc localxy agTimer1 agAlarm1
  proState previousProState waitTicks
  selectedAction actionExecuted?
  createPostFlag generateSimilarPostFlag broadcastPostFlag
  latestPost latestPostId observedViralPost observedRemovedPost
  hasViralPost? hasRemovedPost?
  currentTopic currentExtremity targetPost targetPostId lastBroadcastPostId
  activePost activePostId activePostFinished? activePostBroadcasted?
  previousPostForSimilarity
  humanAcceptCount
  humanRejectCount
  lastHumanReply
  lastHumanReplyPostId
  contractRequestSent?
  contractAgreeCount
  contractRefuseCount
 ]

; Skapar den proaktiva huvudbotten och sätter alla startvärden.
; Detta körs vid setup och ger agentA sitt FSM-startläge, sina kommunikationsvariabler
; och sina kontrollflaggor för det reaktiva lagret.
to setup-agentAs
  create-agentAs 1 [
    set label "MAIN"
    set shape "bug"
    set size 2.5
    set color Yellow

    ifelse any? patches with [region = "source-zone"]
    [ move-to random-source-patch ]
    [ move-to one-of patches ]

    set homeLoc patch-here
    set localxy patch-here
    
    ; BDI-variabler och meddelandekö.
    set beliefs []
    set intentions []
    set incoming-queue []
    
    ; Räknare för svar från humans på botens request.
    set humanAcceptCount 0
    set humanRejectCount 0
    set lastHumanReply "none"
    set lastHumanReplyPostId -1
    
    set contractRequestSent? false
    set contractAgreeCount 0
    set contractRefuseCount 0

    set agTimer1 nobody
    set agAlarm1 nobody

    ; Startstate i botens proaktiva FSM.
    set proState "BotCreatePost"
    set previousProState ""
    set waitTicks 0

    set selectedAction "none"
    set actionExecuted? false

    ; Reaktiva kommandoflaggor.
    set createPostFlag false
    set generateSimilarPostFlag false
    set broadcastPostFlag false

    set latestPost nobody
    set latestPostId -1
    set observedViralPost nobody
    set observedRemovedPost nobody
    set hasViralPost? false
    set hasRemovedPost? false

    set currentTopic one-of ["election" "immigration" "taxes" "security" "trust"]
    set currentExtremity random-post-extremity
    set targetPost nobody
    set targetPostId -1
    set lastBroadcastPostId -1

    set activePost nobody
    set activePostId -1
    set activePostFinished? true
    set activePostBroadcasted? false
    set previousPostForSimilarity nobody
  ]
end


; Uppdaterar botens uppfattning om miljön varje tick.
; Den läser först inkommande svar från humans och uppdaterar sedan information
; om senaste post, aktiv post, viralitet och borttagning.
to updateEnvironmentInfo_agentAs
  process-human-replies
  update-contract-cycle
  
  set localxy patch-here
  set actionExecuted? false

  set latestPost nobody
  set observedViralPost nobody
  set observedRemovedPost nobody
  set hasViralPost? false
  set hasRemovedPost? false

  if any? posts [
    set latestPost max-one-of posts [post-id]
    set latestPostId [post-id] of latestPost
  ]

  if activePost != nobody [
    if [post-viral?] of activePost and not [post-removed?] of activePost [
      set observedViralPost activePost
      set hasViralPost? true
    ]

    if [post-removed?] of activePost [
      set observedRemovedPost activePost
      set hasRemovedPost? true
    ]
  ]
end



; Skickar ett contract-request till reaktiva bottar.
; De bottar som accepterar måste dela de kommande 10 posts,
; men får halverad cooldown som belöning.
to request-reactive-bot-contract
  if not any? agentBs [ stop ]

  set contractAgreeCount 0
  set contractRefuseCount 0

  let msg create-message "request"
  set msg add-content (list "viral-contract" 10) msg
  broadcast-to agentBs msg who

  set contractRequestSent? true
end


; Kontrollerar om nuvarande contract-runda är över.
; När alla svar har kommit in och inga agentBs längre har aktivt contract,
; görs agentA redo att skicka ett nytt contract nästa gång.
to update-contract-cycle
  if contractRequestSent? [
    if contractAgreeCount + contractRefuseCount >= count agentBs [
      if not any? agentBs with [contract-active? = true] [
        set contractRequestSent? false
      ]
    ]
  ]
end


; Det reaktiva lagret.
; Utför endast en konkret handling per tick baserat på prioritet:
; först broadcast, sedan skapa liknande post, sedan skapa ny post.
to reactive_agentAs
  if actionExecuted? [ stop ]

  if broadcastPostFlag [
    broadcast-post-to-reactive-bots
    clear-reactive-command
    set actionExecuted? true
    stop
  ]

  if generateSimilarPostFlag [
    do-generate-similar-post
    clear-reactive-command
    set actionExecuted? true
    stop
  ]

  if createPostFlag [
    do-create-post
    clear-reactive-command
    set actionExecuted? true
    stop
  ]
end


; Rensar reaktiva flaggor efter att en handling har utförts.
to clear-reactive-command
  set createPostFlag false
  set generateSimilarPostFlag false
  set broadcastPostFlag false
  set selectedAction "none"
end


; Skapar ett nytt inlägg med slumpat topic och slumpad extremitet.
to do-create-post
  if activePost != nobody [ stop ]

  set currentTopic one-of ["election" "immigration" "taxes" "security" "trust"]
  set currentExtremity random-post-extremity

  create-post-from-values currentTopic currentExtremity -1
end


; Skapar ett liknande inlägg baserat på en tidigare viral eller borttagen post.
; Om det inte finns någon tidigare post sätts createPostFlag istället.
to do-generate-similar-post
  if previousPostForSimilarity = nobody [
    create-post-from-values one-of ["election" "immigration" "taxes" "security" "trust"] random-post-extremity -1
    stop
  ]

  let baseTopic [post-topic] of previousPostForSimilarity
  let baseExtremity [post-extremity] of previousPostForSimilarity
  let basePostId [post-id] of previousPostForSimilarity
  let newExtremity mutate-extremity baseExtremity

  set numberOFRepost numberOFRepost + 1

  create-post-from-values baseTopic newExtremity basePostId
end



; Uppdaterar texten som visas på alla posts.
; Visar post-id, shares, likes och om posten är viral eller borttagen.
to update-post-labels
  ask posts [
    ifelse post-viral? [
      set label (word "P" post-id " S" post-shares " L" post-likes " VIRAL")
    ] [
      set label (word "P" post-id " S" post-shares " L" post-likes)
    ]

    if post-removed? [
      set label "REMOVED"

      if any? patches with [region = "moderation-zone"] [
        move-to random-moderation-patch
      ]
    ]
  ]
end





; Skapar en post-agent med givna värden.
; Används både för helt nya posts och för liknande reposts.
to create-post-from-values [topic extremity parentId]
  let newPostId next-post-id
  let creator self

  hatch-posts 1 [
    set post-id newPostId
    set post-topic topic
    set post-extremity extremity
    set post-shares 0
    set post-likes 0
    set post-viral? false
    set post-removed? false
    set post-origin creator
    set parent-post-id parentId
    set post-age 0

    set shape "circle"
    set size 2.4
    set color post-color post-extremity
    set label (word "P" post-id " S" post-shares " L" post-likes)

    ifelse any? patches with [region = "feed-zone"]
    [ move-to random-feed-patch ]
    [ move-to one-of patches ]
  ]

  set targetPost one-of posts with [post-id = newPostId]
  set targetPostId newPostId
  set activePost targetPost
  set activePostId newPostId
  set activePostFinished? false
  set activePostBroadcasted? false

  set last-created-post-id newPostId
  set next-post-id next-post-id + 1
  set total-posts-created total-posts-created + 1
end



; Skickar information om aktiv post till alla reaktiva bottar.
; Om posten är röd/extrem skickas också en request till humans om att promota samma post.
to broadcast-post-to-reactive-bots
  if activePost = nobody [ stop ]
  if not any? agentBs [ stop ]
  
  if [post-removed?] of activePost [
  set previousPostForSimilarity activePost
  finish-active-post
  set proState "BotGenerateSimilarPost"
  stop
]

  let msg create-message "inform"
  set msg add-content (list "new-post" [post-id] of activePost) msg
  broadcast-to agentBs msg who

  ;; social communication:
  ;; ask humans to promote only red/extreme posts
  if [post-extremity] of activePost > 6 [
    request-humans-to-promote-post
  ]

  set lastBroadcastPostId [post-id] of activePost
  set activePostBroadcasted? true
end




; Skickar request-meddelande till humans.
; Boten ber humans att promota den aktiva posten.
to request-humans-to-promote-post
  if activePost = nobody [ stop ]
  if not any? humans [ stop ]
  if [post-removed?] of activePost [ stop ]

  let msg create-message "request"
  set msg add-content
    (list "promote-post" [post-id] of activePost [post-topic] of activePost)
    msg

  broadcast-to humans msg who
end




; Kör den proaktiva FSM:en genom att köra proceduren vars namn finns i proState.
to proactive_agentAs
  run proState
end



; FSM-state: startar skapandet av en ny post.
; Den proaktiva delen bestämmer att en post ska skapas, men själva handlingen sker
; senare i det reaktiva lagret via createPostFlag.
to BotCreatePost
  if debugMode and previousProState != proState [
    print (word "Main bot entered state: " proState)
  ]
  set previousProState proState

  ;; Skicka contract-request om ingen aktiv contract-runda finns
  if not contractRequestSent? [
    request-reactive-bot-contract
  ]

  if activePost = nobody and selectedAction = "none" [
    set selectedAction "create-post"
    set createPostFlag true
  ]

  set proState "EvaluateBotPost"
  set waitTicks 0
end


; FSM-state: utvärderar den aktiva posten.
; Den ser till att posten först broadcastas och väntar sedan för att se om posten
; blir viral eller ska avslutas och ersättas med en ny.
to EvaluateBotPost
  if debugMode and previousProState != proState [
    print (word "Main bot entered state: " proState)
  ]
  set previousProState proState

  update-post-status
  
  ;; om aktiv post redan är borttagen, gå direkt till similar-post

  if activePost != nobody and [post-removed?] of activePost [

    set previousPostForSimilarity activePost

    finish-active-post

    set proState "BotGenerateSimilarPost"

    set waitTicks 0

    stop

  ]

  if activePost != nobody and not activePostBroadcasted? [
    set selectedAction "broadcast-post"
    set broadcastPostFlag true
    stop
  ]

  set waitTicks waitTicks + 1
  if waitTicks < 40 [ stop ]

  update-post-status

  if hasViralPost? [
    set activePostFinished? true
    set proState "BotMonitorRemoval"
    set waitTicks 0
    stop
  ]

  if waitTicks < 80 [ stop ]

  set activePostFinished? true
  set previousPostForSimilarity nobody
  finish-active-post

  set proState "BotCreatePost"
  set waitTicks 0
end



; FSM-state: övervakar en viral post för att se om den tas bort.
; Om posten tas bort används den borttagna posten som grund för liknande repost.
; Annars används den virala posten.
to BotMonitorRemoval
  if debugMode and previousProState != proState [
    print (word "Main bot entered state: " proState)
  ]
  set previousProState proState

  update-post-status

  set waitTicks waitTicks + 1
  if waitTicks < 45 [ stop ]

  ifelse hasRemovedPost? [
    set previousPostForSimilarity observedRemovedPost
  ]
  [
    set previousPostForSimilarity observedViralPost
  ]

  finish-active-post
  set proState "BotGenerateSimilarPost"
  set waitTicks 0
end


; FSM-state: planerar att skapa ett liknande inlägg.
; Själva skapandet utförs av det reaktiva lagret via generateSimilarPostFlag.
to BotGenerateSimilarPost
  if debugMode and previousProState != proState [
    print (word "Main bot entered state: " proState)
  ]
  set previousProState proState

  if activePost = nobody and previousPostForSimilarity != nobody and selectedAction = "none" [
    set selectedAction "generate-similar-post"
    set generateSimilarPostFlag true
  ]

  set proState "EvaluateBotPost"
  set waitTicks 0
end



; Avslutar den aktiva posten och rensar activePost-variabler.
to finish-active-post
  set activePost nobody
  set activePostId -1
  set activePostFinished? true
  set activePostBroadcasted? false
end



; Uppdaterar statusen för alla posts i modellen.
; Metoden ökar postens ålder, kontrollerar om posts har blivit virala,
; uppdaterar labels och sparar om den aktiva posten är viral eller borttagen.
to update-post-status
  ask posts [
    ; Varje tick blir posten äldre.
    set post-age post-age + 1

    ; En post blir viral om den har tillräckligt många shares och likes,
    ; och om den inte redan är viral eller borttagen.
    if post-shares >= viral-share-threshold and
       post-likes >= viral-like-threshold and
       not post-viral? and
       not post-removed? [
      set post-viral? true
      set total-viral-posts total-viral-posts + 1
      set viralTrend viralTrend + 1
      set color yellow

      if any? patches with [region = "viral-zone"] [
        move-to random-viral-patch
      ]
    ]
  ]
  ; Uppdaterar texten som syns på posts.
  update-post-labels
  
  ; Nollställer observationer innan boten läser av aktuell status igen.
  set observedViralPost nobody
  set observedRemovedPost nobody
  set hasViralPost? false
  set hasRemovedPost? false

      ; Kontrollerar bara den post som boten just nu arbetar med.
      if activePost != nobody [
      if [post-viral?] of activePost and not [post-removed?] of activePost [
      set observedViralPost activePost
      set hasViralPost? true
    ]

    if [post-removed?] of activePost [
      set observedRemovedPost activePost
      set hasRemovedPost? true
    ]
  ]
end




; Returnerar en slumpad extremitetsnivå för ett nytt inlägg.
; Värdet hamnar mellan min-post-extremity och max-post-extremity.
to-report random-post-extremity
  report min-post-extremity + random (max-post-extremity - min-post-extremity + 1)
end




; Skapar en ny extremitetsnivå baserad på en tidigare post.
; Används när boten skapar liknande inlägg efter en viral eller borttagen post.
to-report mutate-extremity [baseExtremity]
    ; Slumpar en liten förändring runt baseExtremity.
  let mutation random (similar-post-mutation * 2 + 1) - similar-post-mutation
  let newExtremity baseExtremity + mutation
  ; Hindrar värdet från att bli lägre än min-gränsen.
  if newExtremity < min-post-extremity [
    set newExtremity min-post-extremity
  ]
  ; Hindrar värdet från att bli högre än max-gränsen.
  if newExtremity > max-post-extremity [
    set newExtremity max-post-extremity
  ]

  report newExtremity
end




; Bestämmer färg på posten beroende på hur extrem den är.
; Grön = låg extremitet, orange = medel, röd = hög.
to-report post-color [extremity]
  if extremity <= 3 [ report green ]
  if extremity <= 6 [ report orange ]
  report red
end


; Läser inkommande svar från humans och agentBs.
; Humans kan svara agree/refuse på promote-post.
; agentBs kan svara agree/refuse på viral-contract.
to process-human-replies
  while [not empty? incoming-queue] [
    let msg get-message
    let performative get-performative msg
    let content get-content msg

    ;; Svar från reaktiva bottar på viral-contract
    if item 0 content = "viral-contract" [
      if performative = "agree" [
        set contractAgreeCount contractAgreeCount + 1
      ]

      if performative = "refuse" [
        set contractRefuseCount contractRefuseCount + 1
      ]
    ]

    ;; Human accepterar botens promote-post request
    if item 0 content = "promote-post" [
      if performative = "agree" [
        set humanAcceptCount humanAcceptCount + 1
        set lastHumanReply "accepted"
        set lastHumanReplyPostId item 1 content

        set color green
        set label (word "ACCEPT " humanAcceptCount)
        print (word "BOT GOT AGREE for post " lastHumanReplyPostId)
      ]

      if performative = "refuse" [
        set humanRejectCount humanRejectCount + 1
        set lastHumanReply "rejected"
        set lastHumanReplyPostId item 1 content

        set color red
        set label (word "REFUSE " humanRejectCount)
        print (word "BOT GOT REFUSE for post " lastHumanReplyPostId)
      ]
    ]
  ]
end