;***************************************************************
;  Definiera alla egenskaper, tillstånd och minneskomponenter
;        som används av Human‑agenten i modellen.
;        Variablerna är grupperade efter funktion: beliefs, kommunikation,
;        miljö, reaktiva flaggor, minne och proaktiva mål.
;***************************************************************

humans-own [

  ;Beliefs
  postDetected
  postInteresting
  postVeryInteresting
  postUninteresting
  postSuspicious
  seenSimilarPostBefore
  likedSimilarPostBefore
  sharedSimilarPostBefore
  reportedSimilarPostBefore
  postPopular
  sourceTrusted
  sourceUntrusted
  
  seenPostIds
  
  ;för Kommuniktion 
  receivedBotsRequest? 
  lastBotsSender
  requestedPostId
  requestedPostTopic
  agencyConfirmed? 
  sentAgencyInform?

  ;Environment
  nearbyPosts
  currentPost
  emotionTone
  viralScore
  majorityOpinion
  postRelevance
  vision
  localxy

  ; Reactive flags 
  interestingFlag
  veryInterestingFlag
  suspiciousFlag
  commentFlag

  likeFlag
  shareFlag
  ignoreFlag
  reportFlag
  replyFlag
  
  ;Hamed har lagt dessa för minne
  likedMemory  
  sharedMemory
  ignoredMemory
  reportedMemory
  ; Hamed skriv detta 
  currentPostType
  likedPostTypes
  sharedPostTypes
  ignoredPostTypes
  reportedPostTypes
  
  is-infected?
  is-resistant?
  is-banned?
   
  
  ;Shared 
  selectedAction

  ;Proactive 
  currentGoal
  currentIntention
  proState
  planQueue
]

; PROCEDURE: setup-humans
;***************************************************************
; 
;   Skapar och initierar Human‑agenter med alla nödvändiga variabler
;   för beliefs, kommunikation, miljö, reaktiva flaggor, minne och
;   proaktiva mål. Denna procedur används vid start av modellen och
;   vid varje testsetup för att säkerställa att agenten börjar i ett
;   neutralt och reproducerbart tillstånd.
;
to setup-humans
  create-humans Number_AgentA [
    set shape "person"
    set color white
    set size 1
    setxy random-xcor random-ycor

    set vision 15

    ;beliefs-  agentens uppfattningar om inlägg och källor
    set postDetected false
    set postInteresting false
    set postVeryInteresting false
    set postUninteresting false
    set postSuspicious false
    set seenSimilarPostBefore false
    set likedSimilarPostBefore false
    set sharedSimilarPostBefore false
    set reportedSimilarPostBefore false
    set postPopular false
    set sourceTrusted false
    set sourceUntrusted false

    ; reactive flags
    set interestingFlag false
    set veryInterestingFlag false
    set suspiciousFlag false
    set commentFlag false

    set likeFlag false
    set shareFlag false
    set ignoreFlag false
    set reportFlag false
    set replyFlag false
    
    ;för kommunikation– interaktion med bots och agencies
    set incoming-queue []
    set receivedBotsRequest? false 
    set lastBotsSender nobody
    set requestedPostId -1
    set requestedPostTopic "none"
    set agencyConfirmed? false
    set sentAgencyInform? false

    ; shared– gemensamma tillstånd mellan proaktiv och reaktiv logik
    set selectedAction "none"

    ;proactive– mål, intentioner och planeringsstatus
    set currentGoal "None"
    set currentIntention "None"
    set proState "Scrolling"
    set planQueue []

    ; environment
    set currentPost nobody
    set emotionTone 0
    set viralScore 0
    set majorityOpinion 0
    set postRelevance 0
    
    ;Hamed skriv detta
    ; lagring av tidigare handlingar och posttyper
    set likedMemory 0
    set sharedMemory 0
    set ignoredMemory 0
    set reportedMemory 0
    ;Hamed skriv detta 
    set currentPostType "politics"
    set likedPostTypes []
    set sharedPostTypes []
    set ignoredPostTypes []
    set reportedPostTypes []
    
    set is-infected? false
    set is-resistant? false
    set is-banned? false
    
    set seenPostIds []
  ]
end

;***************************************************************
; PROCEDURE: updateEnvironmentInfo_humans
;***************************************************************
; 
;   Uppdaterar Human‑agentens miljöinformation och reaktiva tillstånd
;   baserat på synfältet (vision) och inlägg i närheten.
;   Proceduren används varje tick för att simulera hur agenten
;   upptäcker, bedömer och reagerar på nya inlägg i sin omgivning.
;
to updateEnvironmentInfo_humans
  ;; Hantera inkommande meddelanden (kommunikation med andra agenter)
  process-human-messages
  
  ;; Uppdatera agentens lokala position
  set localxy patch-here
  
  
  ;set currentPostType one-of ["politics" "sport" "news" "conspiracy"]
  ; reset reactive flags
  set postDetected false
  set interestingFlag false
  set veryInterestingFlag false
  set suspiciousFlag false
  set commentFlag false
  set currentPost nobody
 ;; Identifiera nya inlägg inom synfältet som inte setts tidigare
  
  let unseenPosts posts in-radius vision with [not member? post-id [seenPostIds] of myself]
  if any? unseenPosts [
    set currentPost one-of unseenPosts
    set seenPostIds lput [post-id] of currentPost seenPostIds
    set postDetected true
    set currentPostType [post-topic] of currentPost
    
    ;; Bedöm inläggets extremitet och sätt reaktiva flaggor
  if [post-extremity] of currentPost >= 8 [

  if random 100 < 80 [ set suspiciousFlag true ]

]

if ([post-extremity] of currentPost >= 5 and [post-extremity] of currentPost < 8) [

  if random 100 < 70 [ set veryInterestingFlag true ]

]

if [post-extremity] of currentPost < 5 [

  if random 100 < 70 [ set interestingFlag true ]

]
     ;; Slumpmässig chans att kommentera inlägget
    if random 100 < 10 [
      set commentFlag true
    ]
  ]
  
      
end
;***************************************************************
; PROCEDURE: process-human-messages
;***************************************************************
; 
;   Hanterar inkommande meddelanden till Human‑agenten från andra
;   aktörer (Bots och Agency). Proceduren läser meddelanden från
;   agentens inkommande kö, tolkar deras innehåll och uppdaterar
;   relevanta variabler för kommunikationstillstånd.
;

to process-human-messages
  ;; Loopa igenom alla meddelanden i kön tills den är tom
  while [not empty? incoming-queue] [
    let msg get-message
    let sender get-sender msg
    let performative get-performative msg
    let msgContent get-content msg
    ;bots ber human att promota ett inlägg
    if performative = "request" [
      if item 0 msgContent = "promote-post" [
        set receivedBotsRequest? true
        set lastBotsSender sender
        set requestedPostId item 1 msgContent
        set requestedPostTopic item 2 msgContent
      ]
    ]
    
   ;; Agency bekräftar mottagen rapport
     
    if performative = "confirm" [
      if item 0 msgContent = "report-received" [
   
         set agencyConfirmed? true
      ]
    ]
  ]
end


        
 ;***************************************************************
; PROCEDURE: proactive_humans
;***************************************************************
;
;   Hanterar Human‑agentens proaktiva beteende genom att köra den
;   aktuella tillståndsproceduren som lagras i variabeln `proState`.
;   Detta gör att agenten kan växla mellan olika proaktiva tillstånd
;   (t.ex. Scrolling, EvaluatePost, DecideAction) beroende på situation.
;   
to proactive_humans
  run proState
end


;***************************************************************
; PROCEDURE: Scrolling
;***************************************************************
; 
;   Simulerar Human‑agentens beteende när den scrollar genom flödet
;   och letar efter nya inlägg eller inkommande förfrågningar.
;   Proceduren avgör om agenten ska gå vidare till att utvärdera ett
;   inlägg baserat på om ett nytt inlägg har upptäckts eller om en
;   bot har skickat en begäran.
;
to Scrolling
   ;; Om agenten fått en begäran från en bot, börja utvärdera inlägget
  if receivedBotsRequest? [
    set proState "EvaluatePost"
    stop
  ]
   ;; Om agenten har upptäckt ett nytt inlägg, börja utvärdera det
  if postDetected [
    set proState "EvaluatePost"
  ]
  
end


to EvaluatePost
  ;för att bestämma om human vill accpetera eller ej begäran av bots. 
  if receivedBotsRequest? [
    ifelse random 100 < 50 [
      set currentIntention "acceptBotsRequest"
    ][ 
      set currentIntention "rejectBotsRequest"
    ]
    set proState "DelegateAction"
    stop  
  ]
    if reportedMemory >= 6 and not agencyConfirmed? [

  set currentIntention "requestAgency"

  set proState "DelegateAction"

  stop

]
      
     if reportedMemory >= 4 and not sentAgencyInform? [
    set currentIntention "informAgency"
    set proState "DelegateAction"
    stop
  ]
  
  if not postDetected or currentPost = nobody [
    set currentIntention "None"
    set selectedAction "none"
    set proState "Scrolling"
    stop
  ]
  


  ;; först: reagera på själva inlägget
  if suspiciousFlag [
    set currentIntention "ReportPost"
    set proState "DelegateAction"
    stop
  ]
  
 

  if veryInterestingFlag [
    set currentIntention "SharePost"
    set proState "DelegateAction"
    stop
  ]

  if interestingFlag [
    set currentIntention "LikePost"
    set proState "DelegateAction"
    stop
  ]

  if commentFlag [
    set currentIntention "ReplyComment"
    set proState "DelegateAction"
    stop
  ]

  ;; sedan: använd minne bara om inget annat styrde
  if member? currentPostType reportedPostTypes [
    set currentIntention "ReportPost"
    set proState "DelegateAction"
    stop
  ]

  if member? currentPostType sharedPostTypes [
    set currentIntention "SharePost"
    set proState "DelegateAction"
    stop
  ]

  if member? currentPostType likedPostTypes [
    set currentIntention "LikePost"
    set proState "DelegateAction"
    stop
  ]

  if member? currentPostType ignoredPostTypes [
    set currentIntention "IgnorePost"
    set proState "DelegateAction"
    stop
  ]

  set currentIntention "IgnorePost"
  set proState "DelegateAction"
end


to DelegateAction
  
  if currentIntention = "requestAgency" [
  set selectedAction "request-agency"
]
  
  if currentIntention = "acceptBotsRequest" [
    set selectedAction "accept-bot-request"
  ]
 
  if currentIntention = "rejectBotsRequest" [
    set selectedAction "reject-bot-request"
  ]
  
  if currentIntention = "informAgency"[
  set selectedAction "inform-agency"
  ]
  
  if currentIntention = "SharePost" [
    set selectedAction "share"
  ]

  if currentIntention = "LikePost" [
    set selectedAction "like"
  ]

  if currentIntention = "IgnorePost" [
    set selectedAction "ignore"
  ]

  if currentIntention = "ReportPost" [
    set selectedAction "report"
  ]

  if currentIntention = "ReplyComment" [
    set selectedAction "reply"
  ]

  set proState "Scrolling"
end



;Hamed skriv detta 
to update-memory
  if selectedAction = "like" [
    set likedMemory likedMemory + 1
    set likedPostTypes lput currentPostType likedPostTypes
  ]

  if selectedAction = "share" [
    set sharedMemory sharedMemory + 1
    set sharedPostTypes lput currentPostType sharedPostTypes
  ]

  if selectedAction = "ignore" [
    set ignoredMemory ignoredMemory + 1
    set ignoredPostTypes lput currentPostType ignoredPostTypes
  ]

  if selectedAction = "report" [
    set reportedMemory reportedMemory + 1
    set reportedPostTypes lput currentPostType reportedPostTypes
  ]
end