humans-own [

 ;; BELIEFS (perception state)
  postDetected
  postInteresting
  postVeryInteresting
  postUninteresting
  postSuspicious
  seenSimilarPostBefore
  likedSimilarPostBefore
  sharedSimilarPostBefore
  reportedSimilarPostBefore
  postPopular
  sourceTrusted
  sourceUntrusted
  
  seenPostIds
  
  ;; COMMUNICATION VARIABLES
  ;; används av process-human-messages
  receivedBotsRequest? 
  lastBotsSender
  requestedPostId
  requestedPostTopic
  agencyConfirmed? 
  sentAgencyInform?

  ;; ENVIRONMENT STATE
  nearbyPosts
  currentPost
  emotionTone
  viralScore
  majorityOpinion
  postRelevance
  vision
  localxy

 ;; REACTIVE FLAGS
  ;; sätts i updateEnvironmentInfo_humans
  interestingFlag
  veryInterestingFlag
  suspiciousFlag
  commentFlag

  likeFlag
  shareFlag
  ignoreFlag
  reportFlag
  replyFlag
  
  ;Hamed har lagt dessa för minne
  ;; MEMORY (för långsiktigt beteende)
  likedMemory  
  sharedMemory
  ignoredMemory
  reportedMemory
  ; Hamed skriv detta 
  currentPostType
  likedPostTypes
  sharedPostTypes
  ignoredPostTypes
  reportedPostTypes
  
  is-infected?
  is-resistant?
  is-banned?
   
  
  ;; SHARED VARIABLE mellan proaktiv och reaktiv del
  selectedAction

  ;; PROACTIVE FSM-STATE
  currentGoal
  currentIntention
  proState
  planQueue
]


to setup-humans
  create-humans Number_AgentA [
      ;; initiera agentens utseende och position
    set shape "person"
    set color white
    set size 1
    setxy random-xcor random-ycor

    set vision 15

      ;; initiera beliefs
    set postDetected false
    set postInteresting false
    set postVeryInteresting false
    set postUninteresting false
    set postSuspicious false
    set seenSimilarPostBefore false
    set likedSimilarPostBefore false
    set sharedSimilarPostBefore false
    set reportedSimilarPostBefore false
    set postPopular false
    set sourceTrusted false
    set sourceUntrusted false

    ;; initiera reaktiva flaggor
    set interestingFlag false
    set veryInterestingFlag false
    set suspiciousFlag false
    set commentFlag false

    set likeFlag false
    set shareFlag false
    set ignoreFlag false
    set reportFlag false
    set replyFlag false
    
   ;; initiera kommunikationsvariabler
    set incoming-queue []
    set receivedBotsRequest? false 
    set lastBotsSender nobody
    set requestedPostId -1
    set requestedPostTopic "none"
    set agencyConfirmed? false
    set sentAgencyInform? false

  ;; shared variabel mellan proaktiv och reaktiv del
    set selectedAction "none"

   ;; initiera proaktiv FSM
    set currentGoal "None"
    set currentIntention "None"
    set proState "Scrolling"
    set planQueue []

  ;; initiera miljövariabler
    set currentPost nobody
    set emotionTone 0
    set viralScore 0
    set majorityOpinion 0
    set postRelevance 0
    
    ;Hamed skriv detta
     ;; initiera minne
    set likedMemory 0
    set sharedMemory 0
    set ignoredMemory 0
    set reportedMemory 0
    ;Hamed skriv detta 
    set currentPostType "politics"
    set likedPostTypes []
    set sharedPostTypes []
    set ignoredPostTypes []
    set reportedPostTypes []
    
    set is-infected? false
    set is-resistant? false
    set is-banned? false
    
    set seenPostIds []
  ]
end


to updateEnvironmentInfo_humans
   ;; först: ta emot meddelanden (reaktivt)
  
  process-human-messages
  
  set localxy patch-here
  
   ;; nollställ reaktiva flaggor varje tick
  set postDetected false
  set interestingFlag false
  set veryInterestingFlag false
  set suspiciousFlag false
  set commentFlag false
  set currentPost nobody
  
  ;; hitta nya inlägg inom synfältet
  let unseenPosts posts in-radius vision with [not member? post-id [seenPostIds] of myself]
  if any? unseenPosts [
    set currentPost one-of unseenPosts
    set seenPostIds lput [post-id] of currentPost seenPostIds
    set postDetected true
    set currentPostType [post-topic] of currentPost
    
     ;; sätt reaktiva flaggor baserat på extremitet
  if [post-extremity] of currentPost >= 8 [
      
  ;; slumpmässig chans att vilja kommentera
  if random 100 < 80 [ set suspiciousFlag true ]

]

if ([post-extremity] of currentPost >= 5 and [post-extremity] of currentPost < 8) [

  if random 100 < 70 [ set veryInterestingFlag true ]

]

if [post-extremity] of currentPost < 5 [

  if random 100 < 70 [ set interestingFlag true ]

]
    if random 100 < 10 [
      set commentFlag true
    ]
  ]
  
      
end

;; KOMMUNIKATION: ta emot meddelanden från bots och agency

to process-human-messages
  while [not empty? incoming-queue] [
    let msg get-message
    let sender get-sender msg
    let performative get-performative msg
    let msgContent get-content msg
    
    ;bots ber human att promota ett inlägg
    if performative = "request" [
      if item 0 msgContent = "promote-post" [
        set receivedBotsRequest? true
        set lastBotsSender sender
        set requestedPostId item 1 msgContent
        set requestedPostTopic item 2 msgContent
      ]
    ]
    
 ;; agency bekräftar rapport
     
    if performative = "confirm" [
      if item 0 msgContent = "report-received" [
   
         set agencyConfirmed? true
      ]
    ]
  ]
end


        
  ;; PROAKTIV DEL: FSM  


to proactive_humans
  run proState
end


to Scrolling
  ;; om bot skickat request → avbryt scroll och utvärdera
  if receivedBotsRequest? [
    set proState "EvaluatePost"
    stop
  ]
   ;; om nytt inlägg upptäckt → utvärdera
  if postDetected [
    set proState "EvaluatePost"
  ]
  
end


to EvaluatePost
  ;för att bestämma om human vill accpetera eller ej begäran av bots. 
  if receivedBotsRequest? [
    ifelse random 100 < 50 [
      set currentIntention "acceptBotsRequest"
    ][ 
      set currentIntention "rejectBotsRequest"
    ]
    set proState "DelegateAction"
    stop
  ]
   ;; om inget inlägg → gå tillbaka till scrolling
  if not postDetected or currentPost = nobody [
    set currentIntention "None"
    set selectedAction "none"
    set proState "Scrolling"
    stop
  ]
  
  ;; reaktiva triggers styr intentioner
  ;; först: reagera på själva inlägget
  if suspiciousFlag [
    set currentIntention "ReportPost"
    set proState "DelegateAction"
    stop
  ]
  ;; om human rapporterat mycket → informera agency
  
  if reportedMemory >= 4 and not sentAgencyInform? [
    set currentIntention "informAgency"
    set proState "DelegateAction"
    stop
  ]
  

  if veryInterestingFlag [
    set currentIntention "SharePost"
    set proState "DelegateAction"
    stop
  ]

  if interestingFlag [
    set currentIntention "LikePost"
    set proState "DelegateAction"
    stop
  ]

  if commentFlag [
    set currentIntention "ReplyComment"
    set proState "DelegateAction"
    stop
  ]

  ;; minnesbaserat beteende minne används bara om inget annat styrde
  if member? currentPostType reportedPostTypes [
    set currentIntention "ReportPost"
    set proState "DelegateAction"
    stop
  ]

  if member? currentPostType sharedPostTypes [
    set currentIntention "SharePost"
    set proState "DelegateAction"
    stop
  ]

  if member? currentPostType likedPostTypes [
    set currentIntention "LikePost"
    set proState "DelegateAction"
    stop
  ]

  if member? currentPostType ignoredPostTypes [
    set currentIntention "IgnorePost"
    set proState "DelegateAction"
    stop
  ]
  ;; default-intention
  set currentIntention "IgnorePost"
  set proState "DelegateAction"
end


to DelegateAction
  ;; översätt intention → selectedAction (som reaktiv del exekverar)
  
  if currentIntention = "acceptBotsRequest" [
    set selectedAction "accept-bot-request"
  ]
 
  if currentIntention = "rejectBotsRequest" [
    set selectedAction "reject-bot-request"
  ]
  
  if currentIntention = "informAgency"[
  set selectedAction "inform-agency"
  ]
  
  if currentIntention = "SharePost" [
    set selectedAction "share"
  ]

  if currentIntention = "LikePost" [
    set selectedAction "like"
  ]

  if currentIntention = "IgnorePost" [
    set selectedAction "ignore"
  ]

  if currentIntention = "ReportPost" [
    set selectedAction "report"
  ]

  if currentIntention = "ReplyComment" [
    set selectedAction "reply"
  ]

  set proState "Scrolling"
end



;Hamed skriv detta 
;; MINNESUPPDATERING
to update-memory
  if selectedAction = "like" [
    set likedMemory likedMemory + 1
    set likedPostTypes lput currentPostType likedPostTypes
  ]

  if selectedAction = "share" [
    set sharedMemory sharedMemory + 1
    set sharedPostTypes lput currentPostType sharedPostTypes
  ]

  if selectedAction = "ignore" [
    set ignoredMemory ignoredMemory + 1
    set ignoredPostTypes lput currentPostType ignoredPostTypes
  ]

  if selectedAction = "report" [
    set reportedMemory reportedMemory + 1
    set reportedPostTypes lput currentPostType reportedPostTypes
  ]
end