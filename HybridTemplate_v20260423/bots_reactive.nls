; LOGBOOK OF UPDATES IN THIS FILE
; –Date— |––Description———————————–
; 20260426  v2.0  Created the reactive bot agentB with setup logic, start state check and basic FSM variables. (Abdulmajid)
; 20260428  v2.1  Added incoming message handling so agentB can receive inform messages about new posts from agentA. (Abdulmajid)
; 20260502  v2.2  Implemented the reactive FSM states check, decide, share and ignore. (Ali)
; 20260504  v2.3  Added logic for finding the received post by post-id and storing it as currentPost. (Ali)
; 20260506  v2.4  Added decision logic using share-probability, cautious-share-probability and riskTolerance. (Ali)
; 20260508  v2.5  Added cooldown logic to prevent the same bot from sharing too often. (Abdulmajid)
; 20260508  v2.6  Added memory lists sharedPostIds and ignoredPostIds to prevent duplicate sharing and track ignored posts. (Ali)
; 20260510  v2.7  Added do-share logic that increases post-shares, totalShares, total-posts-shared and post-frequency. (Abdulmajid)
; 20260513  v2.8  Added support for removed posts so reactive bots ignore posts that have been removed by agency. (Ali)
; 20260514  v2.9  Added support for banned bots using is-banned?, where banned bots stop acting and show BANNED. (Abdulmajid)
; 20260517  v3.0  Added contract-net style request handling for viral-contract messages from the proactive bot. (Ali)
; 20260520  v3.1  Added agree/refuse replies from agentB back to agentA after receiving a viral-contract request. (Abdulmajid)
; 20260522  v3.2  Added contract-active?, contract-posts-left and contract-cooldown to control contracted sharing behavior. (Ali)
; 20260524  v3.3  Added forced sharing for contracted bots while contract-posts-left is greater than zero. (Abdulmajid)
; 20260527  v3.4  Added reduced cooldown for contracted bots and automatic contract deactivation when the contract is finished. (Abdulmajid)
;***************************************************************


; BESKRIVNING AV KLASSEN
;
; agentB representerar reaktiva bottar i modellen.
;
; Dessa bottar skapar inte egna inlägg utan tar emot meddelanden från bots_proactive
; om nya inlägg som har skapats. Därefter analyserar de inlägget och bestämmer om
; de ska dela eller ignorera det.
;
; Botten använder en enkel tillståndsmaskin (FSM):
; - "check"  : kontrollerar inkommande meddelanden
; - "decide" : bestämmer om inlägget ska delas eller ignoreras
; - "share"  : delar inlägget och ökar antal shares
; - "ignore" : ignorerar inlägget
;
; Botten kan även bli bannad av agency-agenten.
; Om is-banned? = true slutar botten att agera.
;*********************************************************************************************************************************************************

agentBs-own [
  state
  homeLoc
  localxy
  currentMessage
  currentPost
  currentPostId
  sharedPostIds
  ignoredPostIds
  willShare?
  riskTolerance
  shareCooldown

  is-banned?
  post-frequency
  account-age
;; Contract-net variables
  contract-active?
  contract-posts-left
  contract-cooldown
]

; Skapar alla reaktiva bottar och initialiserar deras variabler och starttillstånd.
to setup-agentBs
  create-agentBs Number_AgentB [
    set shape "bug"
    set size 1.4
    set color blue

    ifelse any? patches with [region = "feed-zone"]
    [ move-to random-feed-patch ]
    [ move-to one-of patches ]

    set homeLoc patch-here
    set localxy patch-here

    ; BDI-struktur och meddelandekö
    set beliefs []
    set intentions []
    set incoming-queue []

    ; Första tillståndet i FSM
    set state "check"

    ; Ingen aktiv post eller meddelande vid start
    set currentMessage nobody
    set currentPost nobody
    set currentPostId -1

    ; Minneslistor för delade och ignorerade posts
    set sharedPostIds []
    set ignoredPostIds []

    set willShare? false

    ; Varje bot får olika risktolerans
    set riskTolerance 4 + random 7

    ; Cooldown för att förhindra spam-delning
    set shareCooldown 0

    ; Statistik och status
    set is-banned? false
    set post-frequency 0
    set account-age random 20
    
    set contract-active? false
    set contract-posts-left 0
    set contract-cooldown 5
  ]
end

; Uppdaterar information från omgivningen varje tick.
to updateEnvironmentInfo_agentBs
  set localxy patch-here

  ; Bannade bottar får inte agera längre
  if is-banned? [
    set color violet
    set label "BANNED"
    stop
  ]

  ; Minskar cooldown över tid
  if shareCooldown > 0 [
    set shareCooldown shareCooldown - 1
  ]
end

; Kör den reaktiva FSM-logiken beroende på aktuellt state.
to reactive_agentBs
  ; Stoppar direkt om botten är bannad
  if is-banned? [
    set color violet
    set label "BANNED"
    stop
  ]

  ; Kör rätt metod beroende på state
  if state = "check" [ check-messages stop ]
  if state = "decide" [ decide-share stop ]
  if state = "share" [ do-share stop ]
  if state = "ignore" [ do-ignore stop ]
end

; Läser inkommande meddelanden från incoming-queue.
; Läser inkommande meddelanden från incoming-queue.
to check-messages
  ifelse contract-active? [
  set color violet
  set label "CHECK\nKONTRAKT"
] [
  set color blue
  set label "CHECK"
]

  ; Kontrollerar om kön innehåller meddelanden
  if not empty? incoming-queue [

    ; Hämtar första meddelandet ur kön
    set currentMessage get-message

    ; Kontrollerar att det är ett inform-meddelande
    if get-performative currentMessage = "inform" [
      let content get-content currentMessage

      ; Kontrollerar att innehållet gäller ett nytt inlägg
      if item 0 content = "new-post" [
        set currentPostId item 1 content

        let wantedPostId currentPostId
        set currentPost one-of posts with [post-id = wantedPostId]

        ifelse currentPost != nobody [
          set state "decide"
        ] [
          set state "ignore"
        ]
      ]
    ]

    ; Kontrollerar om det är ett request-meddelande från huvudbotten
    if get-performative currentMessage = "request" [
      let content get-content currentMessage
      let contractSender get-sender currentMessage

      ; Kontrollerar att requesten gäller viral-contract
      if item 0 content = "viral-contract" [

        ; Cirka 30% av reaktiva bottar accepterar avtalet
        ifelse random 100 < 30 [
          set contract-active? true
          set contract-posts-left item 1 content

          let reply create-message "agree"
          set reply add-receiver contractSender reply
          set reply add-content (list "viral-contract" who contract-posts-left) reply
          send reply

          set color green
          set label "CONTRACT"
        ] [
          set contract-active? false
          set contract-posts-left 0

          let reply create-message "refuse"
          set reply add-receiver contractSender reply
          set reply add-content (list "viral-contract" who) reply
          send reply

          set color red
          set label "NO CONTRACT"
        ]
      ]
    ]
  ]
end

; Bestämmer om botten ska dela eller ignorera posten.
to decide-share
  ifelse contract-active? [
  set color violet
  set label "DECIDE\nKONTRAKT"
] [
  set color cyan
  set label "DECIDE"
]

  ; Om posten inte finns -> ignorera
  if currentPost = nobody [
    set state "ignore"
    stop
  ]

  ; Ignorera borttagna posts
  if [post-removed?] of currentPost [
    set state "ignore"
    stop
  ]

  ; Förhindrar dubbel-delning av samma post
  if member? currentPostId sharedPostIds [
    set state "ignore"
    stop
  ]

  ; Botten får inte dela under cooldown
  if shareCooldown > 0 [
    set state "ignore"
    stop
  ]

  ; Om botten har accepterat contract måste den dela posten
  if contract-active? and contract-posts-left > 0 [
    set willShare? true
    set state "share"
    stop
  ]

  ; Grundsannolikhet för delning
  let prob share-probability

  ; Extremare posts ger försiktigare beteende
  if [post-extremity] of currentPost > riskTolerance [
    set prob cautious-share-probability
  ]

  ; Slumpmässigt beslut om delning
  ifelse random 100 < prob [
    set willShare? true
    set state "share"
  ] [
    set willShare? false
    set state "ignore"
  ]
end

; Delar posten och uppdaterar statistik.
to do-share
  ifelse contract-active? [
  set color violet
  set label (word "SHARE\nKONTRAKT " contract-posts-left)
] [
  set color green
  set label "SHARE"
]

  if currentPost != nobody and not [post-removed?] of currentPost [

    ; Uppdaterar postens antal shares
    ask currentPost [
      set post-shares post-shares + 1

      ; Uppdaterar label beroende på viral-status
      ifelse post-viral? [
        set label (word "P" post-id " S" post-shares " L" post-likes " VIRAL")
      ] [
        set label (word "P" post-id " S" post-shares " L" post-likes)
      ]
    ]

    ; Sparar posten i minnet för att undvika dubbel-share
    set sharedPostIds lput currentPostId sharedPostIds

    ; Statistik till modellen och agency-agenten
    set total-posts-shared total-posts-shared + 1
    set totalShares totalShares + 1
    set post-frequency post-frequency + 1

    ; Contracted bots får halverad cooldown och använder 1 contract-post
    ifelse contract-active? and contract-posts-left > 0 [
      set shareCooldown contract-cooldown
      set contract-posts-left contract-posts-left - 1

      if contract-posts-left <= 0 [
        set contract-active? false
        set contract-posts-left 0
        set label "CONTRACT DONE"
      ]
    ] [
      ; Vanliga bottar får normal cooldown
      set shareCooldown 10
    ]
  ]

  ; Återställer botten till start-state
  reset-bot
end

; Ignorerar posten och sparar den i minnet.
to do-ignore
  set color gray
  set label "IGNORE"

  ; Sparar ignorerade posts
  if currentPostId != -1 and not member? currentPostId ignoredPostIds [
    set ignoredPostIds lput currentPostId ignoredPostIds
  ]

  reset-bot
end

; Återställer temporära variabler efter en handling.
to reset-bot
  set currentMessage nobody
  set currentPost nobody
  set currentPostId -1
  set willShare? false

  ; Återgår till första state i FSM
  set state "check"

  ifelse contract-active? [
    set color violet
    set label "CHECK\nKONTRAKT"
  ] [
    set color blue
    set label "CHECK"
  ]
end
