;*********************************************************************************************************************************************************
; VARIABLES OF PATCHES

patches-own [
  neighborhood        ; surrounding patches within the vision radius
  region              ; used for identification of different regions
]

;****************** end variables of patches **************************************************************************************************************

;***********************************************************************************************************************************************************
; SETUP ENVIRONMENT

to setup-environment
  ask patches [
    set neighborhood patches in-radius 2
    set region "feed-zone"
    set pcolor 3
    set plabel ""
  ]

  setup-source-zone
  setup-feed-zone
  setup-viral-zone
  setup-zone-labels
end

;***********************************************************************************************************************************************************
; ENVIRONMENT REGIONS

to setup-source-zone
  ask patches with [pxcor <= min-pxcor + 8] [
    set region "source-zone"
    set pcolor 104
  ]
end

to setup-feed-zone
  ask patches with [
    pxcor > min-pxcor + 8 and
    pxcor < max-pxcor - 10
  ] [
    set region "feed-zone"
    set pcolor 3
  ]
end

to setup-viral-zone
  ask patches with [
    pxcor >= max-pxcor - 10
  ] [
    set region "viral-zone"
    set pcolor 44
  ]
end

to setup-zone-labels
  ask one-of patches with [
    region = "source-zone" and
    pxcor = min-pxcor + 4 and
    pycor = max-pycor - 2
  ] [
    set plabel "SOURCE"
  ]

  ask one-of patches with [
    region = "feed-zone" and
    pxcor = max-pxcor / 2 and
    pycor = min-pycor + 2
  ] [
    set plabel "FEED"
  ]

  ask one-of patches with [
    region = "viral-zone" and
    pxcor = max-pxcor - 5 and
    pycor = max-pycor - 4
  ] [
    set plabel "VIRAL"
  ]
end

;***********************************************************************************************************************************************************
; HELP REPORTERS

to-report random-feed-patch
  report one-of patches with [region = "feed-zone"]
end

to-report random-source-patch
  report one-of patches with [region = "source-zone"]
end

to-report random-viral-patch
  report one-of patches with [region = "viral-zone"]
end

; Kept for compatibility with bot code.
; Since there is no removed zone anymore, removed posts stay in the feed.
to-report random-moderation-patch
  report one-of patches with [region = "feed-zone"]
end

;******************* end environment **********************************************************************************************************************
