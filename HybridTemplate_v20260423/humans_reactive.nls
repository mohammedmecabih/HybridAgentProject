to reactive_humans

  set likeFlag false
  set shareFlag false
  set ignoreFlag false
  set reportFlag false
  set replyFlag false

  ;; Proactive communication actions

  if selectedAction = "broadcast-warning" [
    broadcast-warning
    set selectedAction "none"
    stop
  ]

  if selectedAction = "broadcast-share" [
    broadcast-share
    set selectedAction "none"
    stop
  ]

  if selectedAction = "request-agency" [
    request-agency
    set selectedAction "none"
    stop
  ]

  if selectedAction = "accept-bot-request" [
    accept-bot-request
    set selectedAction "none"
    stop
  ]

  if selectedAction = "reject-bot-request" [
    reject-bot-request
    set selectedAction "none"
    stop
  ]

  if selectedAction = "inform-agency" [
    inform-agency
    set selectedAction "none"
    stop
  ]

  ;; Reactive actions from proactive intention

  if selectedAction = "share" [
    share-post
    update-memory
    set selectedAction "none"
    stop
  ]

  if selectedAction = "like" [
    like-post
    update-memory
    set selectedAction "none"
    stop
  ]

  if selectedAction = "ignore" [
    ignore-post
    update-memory
    set selectedAction "none"
    stop
  ]

  if selectedAction = "report" [
    report-post
    update-memory
    set selectedAction "none"
    stop
  ]

  if selectedAction = "reply" [
    reply-to-comment
    set selectedAction "none"
    stop
  ]

  ;; Fallback reactive logic

  if suspiciousFlag [
    report-post
    stop
  ]

  if veryInterestingFlag [
    share-post
    stop
  ]

  if interestingFlag [
    like-post
    stop
  ]

  if commentFlag [
    reply-to-comment
    stop
  ]

  if postDetected and currentPost != nobody [
    ignore-post
  ]

end


to accept-bot-request
  ;; Human accepts a bot request to promote a post.
  ;; This only concerns communication between human and bot.
  ;; Agency is not involved here.

  let msg create-message "agree"
  set msg add-receiver lastBotsSender msg
  set msg add-content (list "promote-post" requestedPostId) msg
  send msg

  let reqId requestedPostId
  let promotedPost one-of posts with [post-id = reqId]

  if is-agent? promotedPost [
    ask promotedPost [
      set post-likes post-likes + 1
      set post-shares post-shares + 1
    ]

    set totalShares totalShares + 1
    set viralTrend viralTrend + 1

    set likedMemory likedMemory + 1
    set sharedMemory sharedMemory + 1
    set likedPostTypes lput requestedPostTopic likedPostTypes
    set sharedPostTypes lput requestedPostTopic sharedPostTypes
  ]

  ;; Human helps spread the post.
  set color green

  set receivedBotsRequest? false
  set requestedPostId -1
  set requestedPostTopic "none"
  set lastBotsSender nobody
end


to reject-bot-request
  ;; Human refuses a bot request to promote a post.
  ;; Agency is not involved here.

  let rejectedPostId requestedPostId

  let msg create-message "refuse"
  set msg add-receiver lastBotsSender msg
  set msg add-content (list "promote-post" rejectedPostId) msg
  send msg

  set receivedBotsRequest? false
  set requestedPostId -1
  set requestedPostTopic "none"
  set lastBotsSender nobody
end


to inform-agency
  ;; Human sends information to agency.
  ;; Agency should answer with a confirm message.

  if any? agencies [
    let target one-of agencies

    let msg create-message "inform"
    set msg add-receiver [who] of target msg
    set msg add-content (list "suspicious-topic" currentPostType reportedMemory) msg
    send msg

    print (word "HUMAN " who
      " | FIPA SENT inform to agency " [who] of target
      ": suspicious-topic " currentPostType
      " reportedMemory=" reportedMemory)

    set sentAgencyInform? true
    set color orange
  ]
end


to request-agency
  ;; Human sends a separate request to agency.
  ;; This happens when the human reports a post.
  ;; The request contains the exact post-id.

  if currentPost = nobody [ stop ]

  if any? agencies [
    let target one-of agencies
    let requested-id [post-id] of currentPost

    let msg create-message "request"
    set msg add-receiver [who] of target msg
    set msg add-content (list "investigate-post" requested-id) msg
    send msg

    print (word "HUMAN " who
      " | FIPA SENT request to agency " [who] of target
      ": investigate-post P" requested-id)

    set color cyan
  ]
end


to broadcast-warning
  ;; Sends a warning to nearby humans and nearby agencies.

  let nearbyAgents (turtle-set (other humans in-radius 10) (agencies in-radius 10))

  foreach sort nearbyAgents [agent ->
    let msg create-message "inform"
    set msg add-receiver [who] of agent msg
    set msg add-content (list "warning" currentPostType) msg
    send msg
  ]

  set color orange
end


to broadcast-share
  ;; Shares an interesting post with nearby humans and nearby agencies.

  let nearbyAgents (turtle-set (other humans in-radius 10) (agencies in-radius 10))

  foreach sort nearbyAgents [agent ->
    let msg create-message "inform"
    set msg add-receiver [who] of agent msg
    set msg add-content (list "interesting-post" currentPostType) msg
    send msg
  ]

  set color green
end


to like-post
  set color blue

  if currentPost != nobody [
    ask currentPost [
      set post-likes post-likes + 1
    ]
  ]
end


to share-post
  set color green
  set totalShares totalShares + 1
  set viralTrend viralTrend + 1

  if currentPost != nobody [
    ask currentPost [
      set post-shares post-shares + 1
    ]
  ]
end


to ignore-post
  set color gray
end


to report-post
  ;; Human reports the current post.
  ;; Reporting a post triggers a separate agency request.
  ;; This has nothing to do with accepting or refusing bot requests.

  set color red
  set numberOfReports numberOfReports + 1
  set viralTrend viralTrend - 1

  request-agency
end


to reply-to-comment
  set color yellow
end
